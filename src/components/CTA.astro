---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Uw afvallogistiek verdient een sterke partner',
  subtitle = 'Vraag vandaag nog een vrijblijvende offerte aan. Wij reageren binnen 24 uur met een voorstel op maat — afgestemd op uw volumes, frequentie en specifieke eisen. Geen standaardpakketten, maar maatwerk dat past bij uw bedrijfsvoering.',
} = Astro.props;
---

<section class="relative overflow-hidden bg-primary py-20 lg:py-28">
  <!-- Decorative elements -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute -right-32 top-0 h-64 w-64 rounded-full bg-secondary blur-3xl"></div>
    <div class="absolute -left-32 bottom-0 h-64 w-64 rounded-full bg-accent blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-black tracking-tight text-white sm:text-4xl lg:text-5xl">
        {title}
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-white/80">
        {subtitle}
      </p>
      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="/contact/"
          class="inline-flex items-center gap-2 rounded-lg bg-secondary px-8 py-4 text-base font-bold text-white shadow-lg transition-all duration-200 hover:bg-secondary-dark hover:shadow-xl hover:-translate-y-0.5"
        >
          Offerte aanvragen
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a
          href="tel:0765720030"
          class="inline-flex items-center gap-2 rounded-lg border-2 border-white/30 px-8 py-4 text-base font-bold text-white transition-all duration-200 hover:border-white/60 hover:bg-white/10"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          076-572 0030
        </a>
      </div>
    </div>
  </div>
</section>
