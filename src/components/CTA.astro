---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Meer dan goed genoeg — wij denken met u mee',
  subtitle = 'Neem contact op en wij inventariseren samen uw situatie. Geen standaardoplossingen, maar maatwerk. Met de klant meedenken is hoe wij werken — voor Gemeente Breda, Gemeente Oosterhout en het bedrijfsleven.',
} = Astro.props;
---

<section class="bg-primary py-20 lg:py-28">
  <div class="border-t border-white/20"></div>
  <div class="mx-auto max-w-7xl px-4 pt-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center" data-animate>
      <h2 class="text-3xl font-black tracking-tight text-white sm:text-4xl lg:text-5xl">
        {title}
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-white/80">
        {subtitle}
      </p>

      <!-- Large phone number -->
      <a href="tel:0765720030" class="mt-10 block font-heading text-4xl font-black text-secondary sm:text-5xl lg:text-6xl transition-colors hover:text-secondary-light">
        076 – 572 0030
      </a>

      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="/contact/"
          class="inline-flex items-center gap-2 border-2 border-secondary bg-secondary px-8 py-4 text-base font-bold text-white transition-all duration-200 hover:bg-secondary-dark hover:border-secondary-dark"
        >
          Offerte aanvragen
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a
          href="tel:0765720030"
          class="inline-flex items-center gap-2 border-2 border-white/40 px-8 py-4 text-base font-bold text-white transition-all duration-200 hover:border-white/70 hover:bg-white/10"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          Bel direct
        </a>
      </div>
    </div>
  </div>
</section>
