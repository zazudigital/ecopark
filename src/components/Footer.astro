---
import { useTranslations, localePath, type Locale } from '../i18n';

const locale = (Astro.currentLocale || 'nl') as Locale;
const t = useTranslations(locale);

const year = new Date().getFullYear();

const serviceLinks = t('footer.serviceLinks') as Array<{ label: string; anchor: string }>;
const navLinks = [
  { href: localePath(locale, '/'), label: t('nav.home') },
  { href: localePath(locale, '/diensten/'), label: t('nav.diensten') },
  { href: localePath(locale, '/over-ons/'), label: t('nav.overOns') },
  { href: localePath(locale, '/contact/'), label: t('nav.contact') },
];
---

<footer role="contentinfo">
  <!-- Main Footer -->
  <div class="bg-secondary text-white" style="clip-path: polygon(0 3%, 100% 0, 100% 100%, 0 100%);">
    <div class="relative mx-auto max-w-7xl overflow-hidden px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
      <!-- ECOPARK watermark -->
      <div class="pointer-events-none absolute -right-8 top-1/2 -translate-y-1/2 select-none" aria-hidden="true">
        <span class="font-heading text-[12rem] font-black leading-none tracking-tighter text-white/[0.08] lg:text-[18rem]">ECOPARK</span>
      </div>

      <div class="relative grid gap-10 sm:grid-cols-2 lg:grid-cols-4 lg:gap-12">
        <!-- Company Info -->
        <div class="sm:col-span-2 lg:col-span-1 min-w-0">
          <a href={localePath(locale, '/')} class="mb-6 inline-flex items-center gap-3" aria-label="Ecopark Breda">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center bg-white/20">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true">
                <path d="M3 7l6-4 6 4 6-4v14l-6 4-6-4-6 4V7z" stroke="#ffffff" stroke-width="2" stroke-linejoin="round" fill="none"/>
                <path d="M9 3v14M15 7v14" stroke="#ffffff" stroke-width="2"/>
              </svg>
            </div>
            <div class="flex flex-col leading-none min-w-0">
              <span class="text-lg font-black tracking-tight text-white">ECOPARK</span>
              <span class="text-xs font-bold tracking-widest text-white/80">BREDA</span>
            </div>
          </a>
          <p class="mt-4 text-base font-medium leading-relaxed text-white/90 max-w-prose">
            {t('footer.brandDescription')}
          </p>

          <!-- Opening hours -->
          <div class="mt-6 border-t border-white/20 pt-4">
            <p class="text-xs font-bold uppercase tracking-widest text-white/60">{t('footer.openingHoursLabel')}</p>
            <p class="mt-2 text-base font-medium text-white/80">{t('footer.openingHoursValue')}</p>
          </div>
        </div>

        <!-- Services -->
        <nav class="min-w-0" aria-label="Service links">
          <h3 class="footer-heading mb-5 text-xs font-bold uppercase tracking-widest text-white">{t('footer.servicesHeading')}</h3>
          <ul class="space-y-3">
            {serviceLinks.map((link) => (
              <li>
                <a href={localePath(locale, `/diensten/${link.anchor}`)} class="text-base font-medium text-white/80 transition-colors duration-200 hover:text-white break-words">{link.label}</a>
              </li>
            ))}
          </ul>
        </nav>

        <!-- Quick Links -->
        <nav class="min-w-0" aria-label="Quick links">
          <h3 class="footer-heading mb-5 text-xs font-bold uppercase tracking-widest text-white">{t('footer.navigationHeading')}</h3>
          <ul class="space-y-3">
            {navLinks.map((link) => (
              <li>
                <a href={link.href} class="text-base font-medium text-white/80 transition-colors duration-200 hover:text-white">{link.label}</a>
              </li>
            ))}
          </ul>
        </nav>

        <!-- Contact Info -->
        <div class="min-w-0">
          <h3 class="footer-heading mb-5 text-xs font-bold uppercase tracking-widest text-white">{t('footer.contactHeading')}</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
              </svg>
              <address class="text-base font-medium text-white/80 not-italic">
                Nieuwe Bredase Baan 30<br />
                4825 BP Breda
              </address>
            </li>
            <li class="flex items-center gap-3">
              <svg class="h-5 w-5 shrink-0 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              <a href="tel:+31765720030" class="text-base font-medium text-white/80 transition-colors duration-200 hover:text-white">076 – 572 0030</a>
            </li>
          </ul>

          <!-- LinkedIn — prominent -->
          <a
            href="https://www.linkedin.com/company/ecopark-breda"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 flex items-center gap-3 border border-white/20 px-4 py-3 text-white/90 transition-all duration-200 hover:border-white/50 hover:bg-white/10 hover:text-white active:bg-white/15"
            aria-label="Ecopark Breda on LinkedIn"
          >
            <svg class="h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            <span class="text-base font-bold">{t('footer.linkedinLabel')}</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Animated scan line -->
  <div class="relative h-px bg-secondary-dark overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-secondary-light to-transparent animate-scan-line" aria-hidden="true"></div>
  </div>

  <!-- Bottom Bar — Darker green -->
  <div class="bg-secondary-dark">
    <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-3 px-4 py-5 sm:flex-row sm:px-6 lg:px-8">
      <p class="text-base font-medium text-white/70">
        &copy; {year} Ecopark Breda B.V. {t('footer.copyright')}
      </p>
      <p class="text-base font-medium text-white/70">
        {t('footer.vihbKvk')} &middot; KvK 62609645
      </p>
    </div>
  </div>
</footer>
