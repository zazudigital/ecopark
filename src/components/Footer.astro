---
const year = new Date().getFullYear();
---

<footer>
  <!-- Main Footer — Green background -->
  <div class="bg-secondary text-white">
    <div class="relative mx-auto max-w-7xl overflow-hidden px-4 py-16 sm:px-6 lg:px-8">
      <!-- ECOPARK watermark -->
      <div class="pointer-events-none absolute -right-8 top-1/2 -translate-y-1/2 select-none">
        <span class="font-heading text-[12rem] font-black leading-none tracking-tighter text-white/[0.08] lg:text-[18rem]">ECOPARK</span>
      </div>

      <div class="relative grid gap-12 md:grid-cols-2 lg:grid-cols-4">
        <!-- Company Info -->
        <div class="lg:col-span-1">
          <a href="/" class="mb-6 inline-flex items-center gap-3" aria-label="Ecopark Breda">
            <div class="flex h-10 w-10 items-center justify-center bg-white/20">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="h-5 w-5">
                <path d="M3 7l6-4 6 4 6-4v14l-6 4-6-4-6 4V7z" stroke="#ffffff" stroke-width="2" stroke-linejoin="round" fill="none"/>
                <path d="M9 3v14M15 7v14" stroke="#ffffff" stroke-width="2"/>
              </svg>
            </div>
            <div class="flex flex-col leading-none">
              <span class="text-lg font-black tracking-tight text-white">ECOPARK</span>
              <span class="text-xs font-bold tracking-widest text-white/80">BREDA</span>
            </div>
          </a>
          <p class="mt-4 text-sm leading-relaxed text-white/80">
            Professionele afvaloverslag, beveiligde stallingsplaatsen en logistieke dienstverlening op 2.4 hectare verhard terrein aan de Nieuwe Bredase Baan. VIHB gecertificeerd.
          </p>
        </div>

        <!-- Services -->
        <div>
          <h3 class="mb-5 text-xs font-bold uppercase tracking-widest text-white">Diensten</h3>
          <ul class="space-y-3">
            <li>
              <a href="/diensten/#afval-overslag" class="text-sm text-white/80 transition-colors hover:text-white">Afvaloverslag & verwerking</a>
            </li>
            <li>
              <a href="/diensten/#veilige-opslag" class="text-sm text-white/80 transition-colors hover:text-white">Vrachtwagenstalling & parkeren</a>
            </li>
            <li>
              <a href="/diensten/#container-opslag" class="text-sm text-white/80 transition-colors hover:text-white">Containeropslag & beheer</a>
            </li>
            <li>
              <a href="/diensten/#bulk-materiaal" class="text-sm text-white/80 transition-colors hover:text-white">Bulkgoederenoverslag</a>
            </li>
            <li>
              <a href="/diensten/#beveiliging" class="text-sm text-white/80 transition-colors hover:text-white">24/7 Terreinbeveiliging</a>
            </li>
          </ul>
        </div>

        <!-- Quick Links -->
        <div>
          <h3 class="mb-5 text-xs font-bold uppercase tracking-widest text-white">Navigatie</h3>
          <ul class="space-y-3">
            <li>
              <a href="/" class="text-sm text-white/80 transition-colors hover:text-white">Home</a>
            </li>
            <li>
              <a href="/diensten/" class="text-sm text-white/80 transition-colors hover:text-white">Diensten</a>
            </li>
            <li>
              <a href="/over-ons/" class="text-sm text-white/80 transition-colors hover:text-white">Over Ons</a>
            </li>
            <li>
              <a href="/contact/" class="text-sm text-white/80 transition-colors hover:text-white">Contact</a>
            </li>
          </ul>
        </div>

        <!-- Contact Info -->
        <div>
          <h3 class="mb-5 text-xs font-bold uppercase tracking-widest text-white">Contact</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
              </svg>
              <span class="text-sm text-white/80">
                Nieuwe Bredase Baan 30<br />
                4825 BP Breda
              </span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="h-5 w-5 shrink-0 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              <a href="tel:0765720030" class="text-sm text-white/80 transition-colors hover:text-white">076-572 0030</a>
            </li>
            <li class="flex items-center gap-3">
              <svg class="h-5 w-5 shrink-0 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
              </svg>
              <span class="text-sm text-white/80">KvK: 62609645</span>
            </li>
          </ul>

          <!-- Social Links -->
          <div class="mt-6 flex gap-3">
            <a
              href="https://www.linkedin.com/company/ecopark-breda"
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-10 w-10 items-center justify-center border border-white/30 text-white/80 transition-all hover:border-white hover:text-white"
              aria-label="Volg ons op LinkedIn"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar — Darker green -->
  <div class="bg-secondary-dark">
    <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-4 py-6 sm:flex-row sm:px-6 lg:px-8">
      <p class="text-xs text-white/70">
        &copy; {year} Ecopark Breda B.V. Alle rechten voorbehouden.
      </p>
      <p class="text-xs text-white/70">
        VIHB Geregistreerd &middot; KvK 62609645
      </p>
    </div>
  </div>
</footer>
