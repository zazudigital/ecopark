---
import { useTranslations, localePath, type Locale } from '../i18n';

const locale = (Astro.currentLocale || 'nl') as Locale;
const t = useTranslations(locale);

interface Props {
  title: string;
  subtitle: string;
  showCta?: boolean;
  compact?: boolean;
  showStats?: boolean;
}

const { title, subtitle, showCta = true, compact = false, showStats = false } = Astro.props;
---

<section class:list={['relative overflow-hidden', compact ? 'min-h-[50vh]' : 'min-h-[85vh]']}>
  <!-- Background image -->
  <img src="/images/hero-logistics.jpg" alt="Aerial view of Ecopark Breda waste logistics facility with container yard and truck docks" class="absolute inset-0 w-full h-full object-cover object-center" aria-hidden="true" width="1400" height="800" loading="eager" fetchpriority="high" decoding="async" />
  <!-- Clean dark overlay — enough to read white text, subtle image texture -->
  <div class="absolute inset-0 bg-gradient-to-b from-[#0f1740]/92 via-[#152050]/90 to-[#0f1740]/95"></div>
  <!-- Blueprint grid overlay — unique to Ecopark -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 40px 40px;" aria-hidden="true"></div>

  <div class:list={['relative mx-auto flex max-w-7xl flex-col justify-end px-4 sm:px-6 lg:px-8', compact ? 'min-h-[50vh] pb-14 pt-32' : 'min-h-[85vh] pb-20 pt-44']}>
    <div class="max-w-3xl">
      <h1 class:list={[
        'leading-[1.05] tracking-tight text-white text-balance',
        compact ? 'text-3xl sm:text-4xl lg:text-5xl font-bold' : 'text-display font-black'
      ]} style="color: white !important;">
        {title}
      </h1>

      <p class:list={[
        'mt-6 max-w-2xl leading-relaxed text-white/85 font-bold',
        compact ? 'text-base lg:text-lg' : 'text-lg lg:text-xl'
      ]}>
        {subtitle}
      </p>

      {showCta && (
        <div class="mt-12 flex flex-col items-start gap-4 sm:flex-row">
          <a
            href={localePath(locale, '/contact/')}
            class="btn inline-flex items-center gap-2 bg-secondary px-10 py-5 text-lg font-bold text-white transition-all duration-200 hover:bg-secondary-dark hover:shadow-lg hover:-translate-y-px active:translate-y-0"
          >
            {t('hero.ctaPrimary')}
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a
            href={localePath(locale, '/diensten/')}
            class="btn inline-flex items-center gap-2 border-2 border-white/30 px-10 py-5 text-lg font-bold text-white/90 transition-all duration-200 hover:border-white/60 hover:text-white hover:bg-white/5 active:bg-white/10"
          >
            {t('hero.ctaSecondary')}
          </a>
        </div>
      )}
    </div>

    {showStats && (
      <div class="hero-stats-bar mt-16 border-t border-white/15 pt-10">
        <div class="grid grid-cols-2 gap-x-8 gap-y-8 lg:grid-cols-4">
          <!-- Dominant stat: capacity -->
          <div class="min-w-0 col-span-2 lg:col-span-1">
            <span class="stat-number stat-counter text-6xl lg:text-7xl text-white font-black" data-target="180" data-suffix="K" data-duration="2000">0</span>
            <p class="text-base font-bold uppercase tracking-wider text-white/60 mt-2">{t('hero.stats.capacityLabel')}</p>
          </div>
          <div class="min-w-0">
            <span class="stat-number stat-counter text-4xl lg:text-5xl text-white font-bold" data-target="2.4" data-decimals="1" data-duration="1500">0</span>
            <p class="text-base font-bold uppercase tracking-wider text-white/60 mt-2">{t('hero.stats.terrainLabel')}</p>
          </div>
          <div class="min-w-0">
            <span class="stat-number stat-counter text-4xl lg:text-5xl text-white font-bold" data-target="50" data-suffix="+" data-duration="1200">0</span>
            <p class="text-base font-bold uppercase tracking-wider text-white/60 mt-2">{t('hero.stats.trucksLabel')}</p>
          </div>
          <div class="min-w-0">
            <span class="stat-number text-4xl lg:text-5xl text-secondary font-bold">24/7</span>
            <p class="text-base font-bold uppercase tracking-wider text-white/60 mt-2">{t('hero.stats.securityLabel')}</p>
          </div>
        </div>
      </div>
    )}
  </div>
</section>
