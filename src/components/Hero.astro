---
interface Props {
  title: string;
  subtitle: string;
  showCta?: boolean;
  compact?: boolean;
  showStats?: boolean;
}

const { title, subtitle, showCta = true, compact = false, showStats = false } = Astro.props;
---

<section class:list={['relative', compact ? 'min-h-[50vh]' : 'min-h-[75vh]']}>
  <!-- Background image -->
  <img src="/images/hero-logistics.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" aria-hidden="true" width="1400" height="800" />
  <div class="absolute inset-0 bg-primary/90"></div>
  <div class:list={['relative mx-auto flex max-w-7xl flex-col justify-end px-4 sm:px-6 lg:px-8', compact ? 'min-h-[50vh] pb-12 pt-32' : 'min-h-[75vh] pb-16 pt-40']}>
    <div class="max-w-3xl">
      <h1 class:list={[
        'font-black leading-tight tracking-tight text-white',
        compact ? 'text-3xl sm:text-4xl lg:text-5xl' : 'text-4xl sm:text-5xl lg:text-6xl'
      ]}>
        {title}
      </h1>

      <!-- Green horizontal rule below title -->
      <div class="mt-6 h-0.5 w-24 bg-secondary"></div>

      <p class:list={[
        'mt-6 max-w-2xl leading-relaxed text-white/80',
        compact ? 'text-base lg:text-lg' : 'text-lg lg:text-xl'
      ]}>
        {subtitle}
      </p>

      {showCta && (
        <div class="mt-10 flex flex-col items-start gap-4 sm:flex-row">
          <a
            href="/contact/"
            class="inline-flex items-center gap-2 border-2 border-secondary bg-secondary px-8 py-4 text-base font-bold text-white transition-all duration-200 hover:bg-secondary-dark hover:border-secondary-dark"
          >
            Vraag een offerte aan
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a
            href="/diensten/"
            class="inline-flex items-center gap-2 border-2 border-white/40 px-8 py-4 text-base font-bold text-white transition-all duration-200 hover:border-white/70 hover:bg-white/10"
          >
            Bekijk onze diensten
          </a>
        </div>
      )}
    </div>

    {showStats && (
      <div class="mt-12 border-t border-white/20 pt-8">
        <div class="grid grid-cols-2 gap-8 lg:grid-cols-4">
          <div>
            <span class="stat-number text-3xl lg:text-4xl text-secondary">50+</span>
            <span class="ml-2 text-sm font-medium uppercase tracking-wider text-white/70">Vrachtwagens per dag</span>
          </div>
          <div>
            <span class="stat-number text-3xl lg:text-4xl text-secondary">2.4</span>
            <span class="ml-2 text-sm font-medium uppercase tracking-wider text-white/70">Hectare</span>
          </div>
          <div>
            <span class="stat-number text-3xl lg:text-4xl text-secondary">180K</span>
            <span class="ml-2 text-sm font-medium uppercase tracking-wider text-white/70">Ton jaarcapaciteit</span>
          </div>
          <div>
            <span class="stat-number text-3xl lg:text-4xl text-secondary">24/7</span>
            <span class="ml-2 text-sm font-medium uppercase tracking-wider text-white/70">Beveiligd</span>
          </div>
        </div>
      </div>
    )}
  </div>

  <!-- Bottom edge -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-white/20"></div>
</section>
