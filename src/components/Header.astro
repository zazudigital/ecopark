---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/diensten/', label: 'Diensten' },
  { href: '/over-ons/', label: 'Over Ons' },
  { href: '/contact/', label: 'Contact' },
];
---

<div class="fixed top-0 left-0 right-0 z-50" id="header-wrapper">
  <!-- Top contact bar -->
  <div class="hidden bg-[#eceef5] text-xs text-gray-medium md:block transition-all duration-300 overflow-hidden" id="top-bar">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-1.5 sm:px-6 lg:px-8">
      <div class="flex items-center gap-4">
        <a href="tel:0765720030" class="flex items-center gap-1.5 transition-colors hover:text-dark">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
          076 – 572 0030
        </a>
      </div>
      <div class="flex items-center gap-1.5">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" /></svg>
        Nieuwe Bredase Baan 30, Breda
      </div>
    </div>
  </div>

  <header class="bg-white/95 backdrop-blur-sm border-b border-transparent transition-all duration-300" id="site-header">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex h-20 items-center justify-between">
        <!-- Logo + VIHB badge -->
        <div class="flex items-center gap-4">
          <a href="/" class="flex items-center gap-3 group" aria-label="Ecopark Breda - Home">
            <div class="flex h-11 w-11 items-center justify-center bg-primary transition-all duration-200 group-hover:bg-primary-dark group-hover:scale-105">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="h-6 w-6">
                <path d="M3 7l6-4 6 4 6-4v14l-6 4-6-4-6 4V7z" stroke="#ffffff" stroke-width="2" stroke-linejoin="round" fill="none"/>
                <path d="M9 3v14M15 7v14" stroke="#ffffff" stroke-width="2"/>
              </svg>
            </div>
            <div class="flex flex-col leading-none">
              <span class="text-xl font-black tracking-tight text-dark">ECOPARK</span>
              <span class="text-sm font-bold tracking-widest text-primary">BREDA</span>
            </div>
          </a>
          <span class="hidden border border-border px-2 py-0.5 text-[0.625rem] font-bold uppercase tracking-widest text-gray-muted lg:inline-block">VIHB Gecertificeerd</span>
        </div>

        <!-- Desktop Navigation -->
        <nav class="hidden items-center gap-1 md:flex" aria-label="Hoofdnavigatie">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'nav-link px-4 py-2 text-sm font-bold transition-colors duration-200',
                currentPath === link.href
                  ? 'text-primary nav-link-active'
                  : 'text-gray-medium hover:text-dark',
              ]}
              aria-current={currentPath === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          ))}
          <a
            href="/contact/"
            class="ml-3 inline-flex items-center border-2 border-secondary bg-secondary px-5 py-2.5 text-sm font-bold text-white shadow-[0_2px_8px_rgba(57,181,74,0.3)] transition-all duration-200 hover:bg-secondary-dark hover:border-secondary-dark hover:brightness-110 hover:-translate-y-px hover:shadow-[0_4px_16px_rgba(57,181,74,0.4)]"
          >
            Offerte aanvragen
          </a>
        </nav>

        <!-- Mobile Menu Button -->
        <button
          type="button"
          class="inline-flex h-11 w-11 items-center justify-center text-gray-medium transition-colors hover:text-dark md:hidden"
          id="mobile-menu-btn"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Menu openen"
        >
          <svg id="menu-icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <svg id="menu-icon-close" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div
      id="mobile-menu"
      class="hidden border-t border-border bg-white md:hidden"
      role="navigation"
      aria-label="Mobiele navigatie"
    >
      <div class="space-y-1 px-4 py-4">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'block px-4 py-3 text-base font-bold transition-colors duration-200',
              currentPath === link.href
                ? 'text-primary'
                : 'text-gray-medium hover:text-dark',
            ]}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/contact/"
          class="mt-2 block border-2 border-secondary bg-secondary px-4 py-3 text-center text-base font-bold text-white transition-colors hover:bg-secondary-dark hover:border-secondary-dark"
        >
          Offerte aanvragen
        </a>
      </div>
    </div>
  </header>
</div>

<!-- Spacer for fixed header + top bar -->
<div class="h-20 md:h-[calc(5rem+1.625rem)]"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  if (btn && menu && iconOpen && iconClose) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      iconOpen.classList.toggle('hidden');
      iconClose.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
      btn.setAttribute('aria-label', isOpen ? 'Menu openen' : 'Menu sluiten');
    });
  }

  // Add shadow on scroll + hide top bar
  const header = document.getElementById('site-header');
  const topBar = document.getElementById('top-bar');
  const spacer = document.querySelector('[class*="h-20 md:h-"]');
  if (header) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 10) {
        header.classList.add('shadow-sm');
        header.style.borderBottomColor = '#dce3ef';
        if (topBar) {
          topBar.style.maxHeight = '0';
          topBar.style.paddingTop = '0';
          topBar.style.paddingBottom = '0';
        }
      } else {
        header.classList.remove('shadow-sm');
        header.style.borderBottomColor = 'transparent';
        if (topBar) {
          topBar.style.maxHeight = '';
          topBar.style.paddingTop = '';
          topBar.style.paddingBottom = '';
        }
      }
    });
  }
</script>
