---
interface Props {
  number: string;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props;
---

<div class="group border-b border-border py-8 first:border-t first:border-border transition-all duration-200 hover:bg-white/80 hover:border-b-secondary">
  <div class="relative border-t-2 border-transparent transition-colors duration-200 group-hover:border-primary pt-6">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-12 sm:gap-8">
      <!-- Number -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="inline-flex h-10 w-10 items-center justify-center bg-primary/5 transition-all duration-200 group-hover:bg-secondary group-hover:scale-105">
          <span class="stat-number text-xl text-primary transition-colors duration-200 group-hover:text-white">{number}</span>
        </div>
      </div>
      <!-- Content -->
      <div class="sm:col-span-10 lg:col-span-11">
        <h3 class="text-lg font-bold text-dark lg:text-xl">{title}</h3>
        <p class="mt-2 max-w-2xl text-sm leading-relaxed text-gray-medium">{description}</p>
        <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-bold text-primary">
          Meer informatie
          <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </span>
      </div>
    </div>
  </div>
</div>
