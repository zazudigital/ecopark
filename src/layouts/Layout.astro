---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { localeMap, locales, localePath, useTranslations, type Locale } from '../i18n';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const locale = (Astro.currentLocale || 'nl') as Locale;
const t = useTranslations(locale);

const {
  title,
  description = t('meta.defaultDescription'),
  ogImage,
  ogType = 'website',
  schema,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = `${title} | ${t('meta.siteName')}`;
const pagePath = Astro.url.pathname.replace(/^\/(en|de)/, '') || '/';
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {locales.map(l => (
      <link rel="alternate" hreflang={l} href={new URL(localePath(l, pagePath), Astro.site)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(pagePath, Astro.site)} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={localeMap[locale].ogLocale} />
    <meta property="og:site_name" content="Ecopark Breda" />
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site)} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;500;600;700;800&family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <title>{fullTitle}</title>
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  </head>
  <body class="bg-light font-sans text-dark antialiased">
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <script>
      // Enhanced scroll-triggered animation choreography
      function initScrollAnimations() {
        // ── Hero Section — Immediate Entrance ──
        const heroSection = document.querySelector('section[class*="min-h-"]');
        if (heroSection) {
          // Find the main content wrapper inside hero and add choreography class
          const heroContent = heroSection.querySelector('.max-w-3xl');
          if (heroContent) {
            heroContent.classList.add('hero-animate');
            // Trigger hero immediately — no scroll needed
            requestAnimationFrame(() => {
              heroContent.classList.add('is-visible');
            });
          }

          // Stats bar entrance
          const statsBar = heroSection.querySelector('.border-t.border-white\\/15');
          if (statsBar) {
            statsBar.classList.add('hero-stats-animate');
            requestAnimationFrame(() => {
              statsBar.classList.add('is-visible');
            });
          }
        }

        // ── Scroll-triggered Elements ──
        const animateElements = document.querySelectorAll('[data-animate], [data-animate-stagger]');
        if (!animateElements.length) return;

        // Stagger siblings within the same parent section for choreographed entrance
        const sections = new Map<Element, Element[]>();
        animateElements.forEach((el) => {
          const section = el.closest('section') || el.parentElement;
          if (section) {
            if (!sections.has(section)) sections.set(section, []);
            sections.get(section)!.push(el);
          }
        });

        // Apply incremental delays to siblings within the same section
        sections.forEach((elements) => {
          elements.forEach((el, index) => {
            if (index > 0) {
              const delay = index * 100; // 100ms stagger between section siblings
              (el as HTMLElement).style.transitionDelay = `${delay}ms`;
            }
          });
        });

        // Main content observer — generous threshold for smooth reveals
        const contentObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                contentObserver.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.08,
            rootMargin: '0px 0px -60px 0px',
          }
        );

        animateElements.forEach((el) => contentObserver.observe(el));

        // ── Image hover zoom — auto-apply to content images ──
        document.querySelectorAll('section img[loading="lazy"]').forEach((img) => {
          const parent = img.parentElement;
          if (parent && !parent.classList.contains('img-hover-zoom')) {
            parent.classList.add('img-hover-zoom');
          }
        });
      }

      // Run on initial load
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initScrollAnimations);
      } else {
        initScrollAnimations();
      }

      // Re-run after Astro view transitions (if used)
      document.addEventListener('astro:after-swap', initScrollAnimations);
    </script>
  </body>
</html>
