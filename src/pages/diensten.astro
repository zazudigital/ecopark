---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';

const services = [
  {
    id: 'afval-overslag',
    number: '01',
    title: 'Afvaloverslag & Verwerking',
    description: 'Afwikkeling overslag kan sneller — en dat bewijzen wij dagelijks. De gemeenten Breda en Oosterhout leveren het afval hier wekelijks met meer dan vijftig inzamelvoertuigen aan: gft, huishoudelijk afval, grof afval en bijna alle overige voorkomende afvalstoffen. In onze overdekte loods met een jaarcapaciteit van 180.000 ton zorgen wij voor goede scheiding en verkleining, zodat alles snel, schoon en kostenefficiënt getransporteerd wordt. 15 grotere vrachtwagens distribueren het afval naar de afvalcentrales. Strikte hedendaagse eisen waarborgen een professioneel en verantwoord proces.',
    features: [
      'VIHB-geregistreerd: vervoeren, inzamelen, handelen en bemiddelen',
      'Gft, huishoudelijk afval, grof afval en bouw- en sloopafval',
      '180.000 ton jaarcapaciteit in overdekte loods',
      '50+ vrachtwagens dagelijkse aanvoer, 15 vrachtwagens dagelijkse afvoer',
      'Goede scheiding en verkleining voor kostenefficiënt transport',
    ],
  },
  {
    id: 'veilige-opslag',
    number: '02',
    title: 'Vrachtwagenstalling & Beveiligd Parkeren',
    description: 'Moderne en veilige opslag en stalling op het 2,4 hectare grote, volledig bestraatte terrein. Bewaking van goederen, containers en voertuigen met een state-of-the-art systeem van bewakingscamera\'s — niemand betreedt Ecopark ongezien. Verplichte aan- en afmelding bij de portier: netjes en servicegericht. De ligging vlakbij drie snelwegen (A16, A59 en A27) en aan het water maakt Ecopark tot een ideale locatie voor stalling en opslag.',
    features: [
      'Volledig bestraat terrein met ruime parkeerplaatsen',
      'State-of-the-art systeem van bewakingscamera\'s',
      'Verplichte aan- en afmelding bij de portier',
      'Flexibele contracten: dag-, week-, maand- of jaarbasis',
      'Directe ontsluiting naar A16, A59 en A27',
    ],
  },
  {
    id: 'container-opslag',
    number: '03',
    title: 'Containeropslag & Beheer',
    description: 'Ecopark Breda biedt professionele opslagfaciliteiten voor zee-, afval- en opslagcontainers in alle gangbare afmetingen — van 10ft tot 45ft. De ligging vlakbij drie snelwegen en aan het water maakt Ecopark tot een ideale locatie voor containeropslag. Ons volledig bestraatte terrein biedt ruime manoeuvreerruimte voor containerwagens, zodat plaatsing en ophaling snel en efficiënt verlopen. Wij denken met de klant mee voor een oplossing op maat.',
    features: [
      'Opslag van 10ft, 20ft, 40ft en 45ft containers',
      'Volledig bestraatte stalplaatsen met ruime manoeuvreerruimte',
      'Flexibele in- en uitrijprocedures met brede openingstijden',
      'Met de klant meedenken voor oplossingen op maat',
      'Geschikt voor zeecontainers, afvalcontainers en opslagcontainers',
    ],
  },
  {
    id: 'bulk-materiaal',
    number: '04',
    title: 'Bulkgoederenoverslag',
    description: 'Voor aannemers, grondverzetbedrijven en bouwmaterialenleveranciers verzorgt Ecopark Breda de op- en overslag van bulkmaterialen zoals zand, grind, grond, puin en gebroken materialen. Op ons 2,4 hectare grote, volledig bestraatte terrein beschikken wij over gescheiden opslagvakken per materiaalsoort en moderne laad- en losapparatuur. Duurzaamheid staat centraal bij de inrichting van de gehele locatie — goede scheiding zorgt voor kostenefficiënt transport.',
    features: [
      'Gescheiden opslagvakken voor zand, grind, grond, puin en overige bulkmaterialen',
      'Moderne wielladers en laad-/losapparatuur voor snelle verwerking',
      'Duurzaamheid bij de inrichting van de gehele locatie',
      'Tijdelijke tussenopslag en langdurige depotfaciliteiten',
      'Geschikt voor diepladers, kipwagens en bulktransporters',
    ],
  },
  {
    id: 'beveiliging',
    number: '05',
    title: '24/7 Terreinbeveiliging & Surveillance',
    description: 'State-of-the-art systeem van bewakingscamera\'s: niemand betreedt Ecopark ongezien. De veiligheid van uw goederen, voertuigen en materialen is bij ons in professionele handen. Verplichte aan- en afmelding bij de portier zorgt voor overzicht — netjes en servicegericht. Het volledig bestraatte en verlichte terrein, gecombineerd met professionele surveillance, maakt Ecopark Breda tot een van de best beveiligde locaties in de regio.',
    features: [
      'State-of-the-art systeem van bewakingscamera\'s',
      'Niemand betreedt Ecopark ongezien',
      'Verplichte aan- en afmelding bij de portier',
      'Volledig bestraat en verlicht terrein',
      'Professionele surveillance met directe alarmopvolging',
    ],
  },
  {
    id: 'binnenvaart',
    number: '06',
    title: 'Binnenvaart Overslag (Binnenkort Operationeel)',
    description: 'Ecopark Breda grenst aan de rivier de Mark en investeert in een eigen overslagfaciliteit voor transport per schip. Via de Mark naar het Volkerak en Hollandsdiep komt het industriegebied Moerdijk binnen handbereik. Directe overslag van vrachtwagen naar binnenschip vermindert transportbewegingen over de weg en draagt bij aan een schoner milieu. Duurzaamheid en circulaire economische vooruitgang gaan hand in hand.',
    features: [
      'Overslagfaciliteit voor transport per schip',
      'Via de Mark naar Volkerak, Hollandsdiep en Moerdijk',
      'Lagere transportkosten door multimodaal vervoer',
      'Duurzaamheid centraal bij de inrichting',
      'Vermindering van vrachtverkeer en wegcongestie in de regio',
    ],
  },
];
---

<Layout title="Diensten — Afvaloverslag & Logistiek | Ecopark Breda" description="VIHB-gecertificeerde afvaloverslag, beveiligde vrachtwagenstalling, containeropslag, bulkgoederenhandling en 24/7 terreinbeveiliging op 2.4 hectare in Breda.">
  <!-- Hero -->
  <Hero
    title="Met de klant meedenken"
    subtitle="Overslagstation met ambities. Van gft en huishoudelijk afval tot grof afval en bijna alle overige voorkomende afvalstoffen — wij bieden op maat gesneden oplossingen op ons 2,4 hectare grote, volledig bestraatte terrein op bedrijventerrein De Krogten in Breda. De ligging vlakbij drie snelwegen en aan het water maakt Ecopark tot een ideale locatie. Wij denken mee met elke klant voor de beste aanpak."
    showCta={false}
    compact={true}
  />

  <!-- Services Detail -->
  <section class="bg-white py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="space-y-0">
        {services.map((service) => (
          <div id={service.id} class="border-b border-border py-16 first:border-t first:border-border first:pt-0" data-animate>
            <div class="grid items-start gap-12 lg:grid-cols-12">
              <!-- Number -->
              <div class="lg:col-span-2">
                <span class="stat-number text-5xl text-primary lg:text-6xl">{service.number}</span>
              </div>

              <!-- Content -->
              <div class="lg:col-span-6">
                <h2 class="text-2xl font-black text-dark sm:text-3xl">{service.title}</h2>
                {service.id === 'binnenvaart' && (
                  <span class="spec-label mt-3 inline-block border border-secondary bg-secondary/5 px-3 py-1 text-secondary">Binnenkort operationeel</span>
                )}
                <p class="mt-4 text-base leading-relaxed text-gray-medium">{service.description}</p>
              </div>

              <!-- Features -->
              <div class="lg:col-span-4">
                <ul class="space-y-3 border-l-2 border-primary/20 pl-6">
                  {service.features.map((feature) => (
                    <li class="flex items-start gap-3">
                      <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 bg-secondary"></span>
                      <span class="text-sm text-gray-medium">{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Visual break -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-12">
    <img src="/images/containers.jpg" alt="Zeecontainers en opslagcontainers op het Ecopark Breda terrein" loading="lazy" width="800" height="600" class="w-full h-64 object-cover rounded-sm" />
  </div>

  <!-- VIHB Section -->
  <section class="bg-light py-20 lg:py-28">
    <div class="border-t border-border"></div>
    <div class="mx-auto max-w-7xl px-4 pt-20 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center" data-animate>
        <p class="spec-label mb-4">Certificering</p>
        <h2 class="text-3xl font-black tracking-tight text-dark sm:text-4xl">
          VIHB Gecertificeerd
        </h2>
        <div class="mx-auto mt-4 h-0.5 w-16 bg-secondary"></div>
        <p class="mt-6 text-lg leading-relaxed text-gray-medium">
          Ecopark Breda is volledig VIHB-geregistreerd voor het Vervoeren, Inzamelen, Handelen en Bemiddelen van afvalstoffen. Deze registratie bevestigt dat wij voldoen aan alle wettelijke eisen voor professioneel afvalbeheer. Wij werken voor Gemeente Breda en Gemeente Oosterhout en verwerken dagelijks gft, huishoudelijk afval, grof afval en bouw- en sloopafval. Voor u als klant betekent dit zekerheid: een sluitende administratie en de garantie dat uw afvalstromen via gecertificeerde kanalen worden verwerkt.
        </p>
        <div class="mt-10 grid gap-px bg-border sm:grid-cols-4">
          <div class="bg-white p-6">
            <p class="text-2xl font-black text-primary">V</p>
            <p class="mt-1 text-sm font-bold text-gray-medium">Vervoeren</p>
          </div>
          <div class="bg-white p-6">
            <p class="text-2xl font-black text-primary">I</p>
            <p class="mt-1 text-sm font-bold text-gray-medium">Inzamelen</p>
          </div>
          <div class="bg-white p-6">
            <p class="text-2xl font-black text-primary">H</p>
            <p class="mt-1 text-sm font-bold text-gray-medium">Handelen</p>
          </div>
          <div class="bg-white p-6">
            <p class="text-2xl font-black text-primary">B</p>
            <p class="mt-1 text-sm font-bold text-gray-medium">Bemiddelen</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    title="Wij denken graag met u mee"
    subtitle="Bel ons op 076 – 572 0030 of vraag direct een offerte aan. Wij inventariseren uw situatie en stellen een voorstel op maat samen. Met de klant meedenken — dat is hoe wij werken."
  />
</Layout>
