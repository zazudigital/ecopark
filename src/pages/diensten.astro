---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';

const services = [
  {
    id: 'afval-overslag',
    number: '01',
    title: 'Afvaloverslag & Verwerking',
    description: 'Als VIHB-geregistreerd bedrijf verzorgt Ecopark Breda de complete overslag van bedrijfsafval, bouw- en sloopafval, groenafval en overige reststromen. Elke vracht wordt gewogen op onze geautomatiseerde weegbruggen en geregistreerd met volledige afvalstoffendocumentatie. Wij werken samen met gecertificeerde verwerkers om maximale recycling en verantwoorde eindverwerking te garanderen. Zo beschikt u altijd over een sluitende administratie die voldoet aan de eisen van de Inspectie Leefomgeving en Transport.',
    features: [
      'VIHB-geregistreerd: vervoeren, inzamelen, handelen en bemiddelen',
      'Gescheiden overslag van bouw- en sloopafval, bedrijfsafval, groenafval en grond',
      'Geautomatiseerde weegbruggen met digitale vrachtregistratie',
      'Volledige afvalstoffendocumentatie conform Wet milieubeheer',
      'Doorvoer naar gecertificeerde verwerkers voor maximale recycling',
    ],
  },
  {
    id: 'veilige-opslag',
    number: '02',
    title: 'Vrachtwagenstalling & Beveiligd Parkeren',
    description: 'Transportbedrijven vertrouwen op Ecopark Breda voor de beveiligde stalling van hun wagenpark. Op ons 2.4 hectare grote, volledig verharde terrein bieden wij ruime parkeerplaatsen voor vrachtwagens, trekkers, opleggers en bakwagens. Het terrein is 24 uur per dag, 7 dagen per week bewaakt met een geavanceerd IP-camerasysteem, volledige omheining met toegangscontrole en professionele surveillance. Ideaal voor chauffeurs die in de regio Breda overnachten of bedrijven die een vaste stallingslocatie zoeken nabij de A16 en A27.',
    features: [
      'Ruime verharde parkeerplaatsen voor alle voertuigtypen',
      '24/7 IP-camerabewaking met opname en live monitoring',
      'Volledig omheind terrein met gecontroleerde toegang',
      'Flexibele contracten: dag-, week-, maand- of jaarbasis',
      'Directe ontsluiting naar A16 en A27 voor optimale bereikbaarheid',
    ],
  },
  {
    id: 'container-opslag',
    number: '03',
    title: 'Containeropslag & Beheer',
    description: 'Ecopark Breda biedt professionele opslagfaciliteiten voor zee-, afval- en opslagcontainers in alle gangbare afmetingen — van 10ft tot 45ft. Ons terrein is ingericht met ruime rijbanen voor containerwagens en reachstackers, zodat plaatsing en ophaling snel en efficiënt verlopen. Of u nu tijdelijk extra opslagruimte nodig heeft of een vaste stallingsplaats voor uw containerpark zoekt: wij bieden flexibele oplossingen met overzichtelijke registratie en snelle doorlooptijden.',
    features: [
      'Opslag van 10ft, 20ft, 40ft en 45ft containers',
      'Verharde stalplaatsen met ruime manoeuvreerruimte',
      'Flexibele in- en uitrijprocedures met brede openingstijden',
      'Overzichtelijke registratie en containertracking',
      'Geschikt voor zeecontainers, afvalcontainers en opslagcontainers',
    ],
  },
  {
    id: 'bulk-materiaal',
    number: '04',
    title: 'Bulkgoederenoverslag',
    description: 'Voor aannemers, grondverzetbedrijven en bouwmaterialenleveranciers verzorgt Ecopark Breda de op- en overslag van bulkmaterialen zoals zand, grind, grond, puin en gebroken materialen. Ons terrein beschikt over gescheiden opslagvakken per materiaalsoort, moderne laad- en losapparatuur en geautomatiseerde weegbruggen voor nauwkeurige volumeregistratie. Zowel tijdelijke tussenopslag als langdurige depotfaciliteiten zijn mogelijk, afgestemd op uw projectplanning en volumes.',
    features: [
      'Gescheiden opslagvakken voor zand, grind, grond, puin en overige bulkmaterialen',
      'Moderne wielladers en laad-/losapparatuur voor snelle verwerking',
      'Geautomatiseerde weegbruggen met nauwkeurige tonnageregistratie',
      'Tijdelijke tussenopslag en langdurige depotfaciliteiten',
      'Geschikt voor diepladers, kipwagens en bulktransporters',
    ],
  },
  {
    id: 'beveiliging',
    number: '05',
    title: '24/7 Terreinbeveiliging & Surveillance',
    description: 'De veiligheid van uw goederen, voertuigen en materialen is bij Ecopark Breda in professionele handen. Ons beveiligingssysteem omvat een netwerk van IP-camera\'s met 24/7 live monitoring en opname, volledige terreinomheining met gecontroleerde toegangspoorten en intensieve nachtverlichting. Een professionele beveiligingsdienst voert regelmatige surveillancerondes uit en reageert direct bij meldingen. Dit maakt Ecopark Breda tot een van de best beveiligde logistieke terreinen in de regio.',
    features: [
      'Uitgebreid IP-camerasysteem met 24/7 live monitoring en opname',
      'Professionele beveiligingsdienst met regelmatige surveillancerondes',
      'Volledig omheind terrein met elektronische toegangscontrole',
      'Intensieve nachtverlichting over het gehele terrein',
      'Directe alarmopvolging en snelle responstijd bij incidenten',
    ],
  },
  {
    id: 'binnenvaart',
    number: '06',
    title: 'Binnenvaart Overslag (Binnenkort Operationeel)',
    description: 'Ecopark Breda investeert in een eigen overslagfaciliteit voor de binnenvaart. Deze uitbreiding maakt directe overslag van vrachtwagen naar binnenschip mogelijk, waardoor de logistieke keten wordt verkort en transportkosten dalen. Door gebruik te maken van het Brabantse vaarwegennetwerk bieden wij onze klanten een duurzaam alternatief voor wegtransport, met aanzienlijke reductie van CO2-uitstoot en vermindering van congestie op de regionale wegen.',
    features: [
      'Directe overslag van vrachtwagen naar binnenschip en vice versa',
      'Aansluiting op het Brabantse en Zuid-Nederlandse vaarwegennetwerk',
      'Lagere transportkosten door multimodaal vervoer',
      'Significante CO2-reductie ten opzichte van volledig wegtransport',
      'Vermindering van vrachtverkeer en wegcongestie in de regio Breda',
    ],
  },
];
---

<Layout title="Diensten — Ecopark Breda | Afvaloverslag, Stalling, Containeropslag & Beveiliging" description="VIHB-gecertificeerde afvaloverslag, beveiligde vrachtwagenstalling, containeropslag, bulkgoederenhandling en 24/7 terreinbeveiliging op 2.4 hectare in Breda.">
  <!-- Hero -->
  <Hero
    title="Diensten op maat voor de logistieke sector"
    subtitle="Afvaloverslag, beveiligde stalling, containeropslag en bulkgoederenhandling — alles op één strategisch gelegen terrein in Breda. Wij ontzorgen transportbedrijven, afvalverwerkers, aannemers en logistieke dienstverleners met efficiënte processen en capaciteit die meegroeit met uw behoefte."
    showCta={false}
    compact={true}
  />

  <!-- Services Detail -->
  <section class="bg-dark py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="space-y-0">
        {services.map((service) => (
          <div id={service.id} class="border-b border-white/10 py-16 first:border-t first:border-white/10 first:pt-0">
            <div class="grid items-start gap-12 lg:grid-cols-12">
              <!-- Number -->
              <div class="lg:col-span-2">
                <span class="stat-number text-5xl text-secondary lg:text-6xl">{service.number}</span>
              </div>

              <!-- Content -->
              <div class="lg:col-span-6">
                <h2 class="text-2xl font-black text-white sm:text-3xl">{service.title}</h2>
                {service.id === 'binnenvaart' && (
                  <span class="spec-label mt-3 inline-block border border-secondary px-3 py-1">Binnenkort operationeel</span>
                )}
                <p class="mt-4 text-base leading-relaxed text-white/50">{service.description}</p>
              </div>

              <!-- Features -->
              <div class="lg:col-span-4">
                <ul class="space-y-3 border-l border-white/10 pl-6">
                  {service.features.map((feature) => (
                    <li class="flex items-start gap-3">
                      <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 bg-secondary"></span>
                      <span class="text-sm text-white/50">{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VIHB Section -->
  <section class="bg-darker py-20 lg:py-28">
    <div class="border-t border-white/10"></div>
    <div class="mx-auto max-w-7xl px-4 pt-20 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="spec-label mb-4">Certificering</p>
        <h2 class="text-3xl font-black tracking-tight text-white sm:text-4xl">
          VIHB Gecertificeerd
        </h2>
        <div class="mx-auto mt-4 h-0.5 w-16 bg-secondary"></div>
        <p class="mt-6 text-lg leading-relaxed text-white/50">
          Ecopark Breda is volledig VIHB-geregistreerd voor het Vervoeren, Inzamelen, Handelen en Bemiddelen van afvalstoffen. Deze registratie bij de Nationale en Internationale Wegvervoer Organisatie (NIWO) bevestigt dat wij voldoen aan alle wettelijke eisen voor professioneel afvalbeheer. Voor u als klant betekent dit zekerheid: een sluitende administratie, correcte afvalstoffendocumentatie en de garantie dat uw afvalstromen via gecertificeerde kanalen worden verwerkt.
        </p>
        <div class="mt-10 grid gap-px bg-white/10 sm:grid-cols-4">
          <div class="bg-darker p-6">
            <p class="text-2xl font-black text-secondary">V</p>
            <p class="mt-1 text-sm font-bold text-white/40">Vervoeren</p>
          </div>
          <div class="bg-darker p-6">
            <p class="text-2xl font-black text-secondary">I</p>
            <p class="mt-1 text-sm font-bold text-white/40">Inzamelen</p>
          </div>
          <div class="bg-darker p-6">
            <p class="text-2xl font-black text-secondary">H</p>
            <p class="mt-1 text-sm font-bold text-white/40">Handelen</p>
          </div>
          <div class="bg-darker p-6">
            <p class="text-2xl font-black text-secondary">B</p>
            <p class="mt-1 text-sm font-bold text-white/40">Bemiddelen</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    title="Op zoek naar een betrouwbare overslagpartner?"
    subtitle="Bel ons op 076-572 0030 of vraag direct een offerte aan. Wij inventariseren uw volumes en frequentie en stellen binnen 24 uur een voorstel op maat samen — afgestemd op uw specifieke logistieke situatie."
  />
</Layout>
