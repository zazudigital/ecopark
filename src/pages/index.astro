---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTA from '../components/CTA.astro';

const services = [
  {
    number: '01',
    title: 'Afvaloverslag & Verwerking',
    description: 'VIHB-gecertificeerde overslag van bouw- en sloopafval, bedrijfsafval en groenafval. Geautomatiseerde weegbruggen registreren elke vracht nauwkeurig, zodat u altijd beschikt over volledige afvalstoffendocumentatie conform de wet.',
  },
  {
    number: '02',
    title: 'Vrachtwagenstalling & Parkeren',
    description: 'Beveiligde stallingsplaatsen voor vrachtwagens, trekkers en opleggers op 2.4 hectare volledig verhard terrein. 24/7 camerabewaking, hekwerken en professionele surveillance garanderen de veiligheid van uw wagenpark.',
  },
  {
    number: '03',
    title: 'Containeropslag & Beheer',
    description: 'Professionele opslag voor zee-, afval- en opslagcontainers in alle gangbare afmetingen. Ons terrein biedt ruime manoeuvreerruimte voor containerwagens en is ingericht voor snelle in- en uitrijprocedures.',
  },
  {
    number: '04',
    title: 'Bulkgoederenoverslag',
    description: 'Op- en overslag van zand, grind, grond, puin en andere bulkmaterialen met moderne laad- en losapparatuur. Geschikt voor grote volumes, met nauwkeurige weging en gescheiden opslagvakken per materiaalsoort.',
  },
  {
    number: '05',
    title: '24/7 Terreinbeveiliging',
    description: 'Geavanceerd beveiligingssysteem met IP-camerabewaking, omheining met toegangscontrole en nachtverlichting over het gehele terrein. Professionele surveillance beschermt uw goederen en voertuigen dag en nacht.',
  },
  {
    number: '06',
    title: 'Binnenvaart Overslag',
    description: 'Binnenkort operationeel: onze overslagfaciliteit voor binnenvaart. Directe overslag van vrachtwagen naar schip vermindert wegverkeer en CO2-uitstoot, met aansluiting op het Brabantse vaarwegennetwerk.',
  },
];
---

<Layout title="Ecopark Breda — Afvaloverslag, Vrachtwagenstalling & Logistiek Hub in Breda">
  <!-- Hero Section with Stats integrated -->
  <Hero
    title="De schakel tussen afval en herbestemming"
    subtitle="Ecopark Breda is het logistieke knooppunt waar afvalstromen, vrachtverkeer en bulkgoederen samenkomen. Op ons 2.4 hectare grote, volledig verharde terrein aan de Nieuwe Bredase Baan verzorgen wij VIHB-gecertificeerde overslag, beveiligde stalling en efficiënte goederenhandling — 365 dagen per jaar."
    showStats={true}
  />

  <!-- Services Section — Alternating full-width rows -->
  <section class="bg-dark py-16 lg:py-24" id="diensten">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16 max-w-2xl">
        <p class="spec-label mb-3">Onze kernactiviteiten</p>
        <h2 class="text-3xl font-black tracking-tight text-white sm:text-4xl">
          Compleet aanbod voor de logistieke sector
        </h2>
        <p class="mt-4 text-lg text-white/50">
          Van afvaloverslag en gescheiden inzameling tot beveiligde vrachtwagenstalling en bulkgoederenhandling — alles op één professioneel terrein, strategisch gelegen nabij de A16 en A27.
        </p>
      </div>

      <div>
        {services.map((service) => (
          <a href="/diensten/" class="block">
            <ServiceCard
              number={service.number}
              title={service.title}
              description={service.description}
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Facility Section — Spec sheet style -->
  <section class="bg-darker py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16 max-w-2xl">
        <p class="spec-label mb-3">Ons Terrein</p>
        <h2 class="text-3xl font-black tracking-tight text-white sm:text-4xl">
          Gebouwd voor zwaar logistiek verkeer
        </h2>
        <div class="mt-4 h-0.5 w-16 bg-secondary"></div>
      </div>

      <div class="grid gap-px bg-white/10 sm:grid-cols-2 lg:grid-cols-3">
        <div class="bg-darker p-8">
          <span class="spec-label">Terrein</span>
          <p class="mt-2 text-lg font-bold text-white">2.4 hectare verhard</p>
        </div>
        <div class="bg-darker p-8">
          <span class="spec-label">Beveiliging</span>
          <p class="mt-2 text-lg font-bold text-white">24/7 IP-camera + surveillance</p>
        </div>
        <div class="bg-darker p-8">
          <span class="spec-label">Capaciteit</span>
          <p class="mt-2 text-lg font-bold text-white">Meerdere vrachtwagens gelijktijdig</p>
        </div>
        <div class="bg-darker p-8">
          <span class="spec-label">Certificering</span>
          <p class="mt-2 text-lg font-bold text-white">VIHB geregistreerd</p>
        </div>
        <div class="bg-darker p-8">
          <span class="spec-label">Locatie</span>
          <p class="mt-2 text-lg font-bold text-white">Nieuwe Bredase Baan 30, Breda</p>
        </div>
        <div class="bg-darker p-8">
          <span class="spec-label">Ontsluiting</span>
          <p class="mt-2 text-lg font-bold text-white">A16 & A27 directe toegang</p>
        </div>
        <div class="bg-darker p-8">
          <span class="spec-label">Verharding</span>
          <p class="mt-2 text-lg font-bold text-white">Bestand tegen diepladers & containerwagens</p>
        </div>
        <div class="bg-darker p-8">
          <span class="spec-label">Weging</span>
          <p class="mt-2 text-lg font-bold text-white">Geautomatiseerde weegbruggen</p>
        </div>
        <div class="bg-darker p-8">
          <span class="spec-label">Operationeel</span>
          <p class="mt-2 text-lg font-bold text-white">365 dagen per jaar</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Future Plans Section — Industrial announcement style -->
  <section class="bg-dark py-20 lg:py-28">
    <div class="border-t border-white/10"></div>
    <div class="mx-auto max-w-7xl px-4 pt-20 sm:px-6 lg:px-8">
      <div class="grid items-start gap-12 lg:grid-cols-2">
        <div>
          <span class="spec-label inline-block border border-secondary px-3 py-1 mb-6">Binnenkort operationeel</span>
          <h2 class="text-3xl font-black text-white sm:text-4xl">
            Binnenvaart Overslagfaciliteit
          </h2>
          <div class="mt-4 h-0.5 w-16 bg-secondary"></div>
          <p class="mt-6 text-lg leading-relaxed text-white/60">
            Ecopark Breda investeert in een eigen binnenvaart overslagfaciliteit. Door directe overslag van vrachtwagen naar binnenschip verkorten wij de logistieke keten, verlagen wij transportkosten en dragen wij bij aan vermindering van CO2-uitstoot en wegcongestie in de regio Breda en West-Brabant.
          </p>
        </div>
        <div class="lg:pt-4">
          <ul class="space-y-4 border-l border-white/10 pl-6">
            <li class="flex items-start gap-3">
              <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 bg-secondary"></span>
              <span class="text-white/70">Minder wegverkeer en CO2-uitstoot</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 bg-secondary"></span>
              <span class="text-white/70">Aansluiting op Brabants vaarwegennetwerk</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 bg-secondary"></span>
              <span class="text-white/70">Lagere transportkosten per ton</span>
            </li>
          </ul>
          <a href="/contact/" class="mt-8 inline-flex items-center gap-2 border-2 border-secondary px-6 py-3 text-sm font-bold text-secondary transition-colors hover:bg-secondary hover:text-white">
            Vraag meer informatie aan
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTA />
</Layout>
