---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTA from '../components/CTA.astro';

const services = [
  {
    number: '01',
    title: 'Afvaloverslag & Verwerking',
    description: 'Dagelijks leveren meer dan 50 vrachtwagens gft, huishoudelijk afval, grof afval en bouw- en sloopafval aan op ons terrein. In onze overdekte loods met een jaarcapaciteit van 180.000 ton zorgen wij voor goede scheiding en verkleining, zodat afval snel, schoon en kostenefficiënt naar verwerkingslocaties getransporteerd kan worden. 15 grotere vrachtwagens verzorgen dagelijks het transport naar de verwerkers.',
  },
  {
    number: '02',
    title: 'Vrachtwagenstalling & Parkeren',
    description: 'Beveiligde stallingsplaatsen voor vrachtwagens, trekkers en opleggers op ons 2,4 hectare grote, volledig bestraatte terrein. Een state-of-the-art systeem van bewakingscamera\'s zorgt ervoor dat niemand Ecopark ongezien betreedt. Verplichte aan- en afmelding bij de portier: netjes en servicegericht.',
  },
  {
    number: '03',
    title: 'Containeropslag & Beheer',
    description: 'Professionele opslag voor zee-, afval- en opslagcontainers in alle gangbare afmetingen. Ons volledig bestraatte terrein biedt ruime manoeuvreerruimte voor containerwagens en is ingericht voor snelle in- en uitrijprocedures. Wij denken met de klant mee voor een oplossing op maat.',
  },
  {
    number: '04',
    title: 'Bulkgoederenoverslag',
    description: 'Op- en overslag van zand, grind, grond, puin en andere bulkmaterialen. Ons terrein beschikt over gescheiden opslagvakken per materiaalsoort en moderne laad- en losapparatuur. Duurzaamheid staat centraal bij de inrichting van de gehele locatie.',
  },
  {
    number: '05',
    title: '24/7 Terreinbeveiliging',
    description: 'State-of-the-art systeem van bewakingscamera\'s: niemand betreedt Ecopark ongezien. Verplichte aan- en afmelding bij de portier garandeert overzicht en controle. Professionele surveillance beschermt uw goederen en voertuigen dag en nacht.',
  },
  {
    number: '06',
    title: 'Binnenvaart Overslag',
    description: 'Binnenkort operationeel: onze overslagfaciliteit voor transport per schip. Directe overslag van vrachtwagen naar binnenschip vermindert wegverkeer en CO2-uitstoot, met aansluiting op het Brabantse vaarwegennetwerk.',
  },
];
---

<Layout title="Ecopark Breda — Afvaloverslag, Vrachtwagenstalling & Logistiek Hub in Breda">
  <!-- Hero Section with Stats integrated -->
  <Hero
    title="Meer dan goed genoeg"
    subtitle="Ecopark Breda is het professionele op- en overslagpark waar dagelijks meer dan 50 vrachtwagens gft, huishoudelijk en grof afval aanleveren. Op ons 2,4 hectare grote, volledig bestraatte terrein verzorgen wij VIHB-geregistreerde overslag met een jaarcapaciteit van 180.000 ton — voor Gemeente Breda, Gemeente Oosterhout en het bedrijfsleven."
    showStats={true}
  />

  <!-- Services Section — Alternating full-width rows -->
  <section class="bg-white py-16 lg:py-24" id="diensten">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16 max-w-2xl">
        <p class="spec-label mb-3">Onze kernactiviteiten</p>
        <h2 class="text-3xl font-black tracking-tight text-dark sm:text-4xl">
          Meer goed doen dan waar je goed in bent
        </h2>
        <p class="mt-4 text-lg text-gray-medium">
          Van gft en huishoudelijk afval tot bouw- en sloopafval — wij verzorgen de complete op- en overslag voor Gemeente Breda, Gemeente Oosterhout en het bedrijfsleven. Goede scheiding en verkleining zorgen ervoor dat alles snel, schoon en kostenefficiënt getransporteerd wordt.
        </p>
      </div>

      <div class="mb-12">
        <img src="/images/trucks.jpg" alt="Vrachtwagens op het Ecopark Breda terrein" loading="lazy" width="800" height="600" class="w-full h-64 object-cover rounded-sm" />
      </div>

      <div>
        {services.map((service) => (
          <a href="/diensten/" class="block">
            <ServiceCard
              number={service.number}
              title={service.title}
              description={service.description}
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Facility Section — Spec sheet style -->
  <section class="bg-light py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16 max-w-2xl">
        <p class="spec-label mb-3">Ons Terrein</p>
        <h2 class="text-3xl font-black tracking-tight text-dark sm:text-4xl">
          Volledig bestraat, professioneel park
        </h2>
        <div class="mt-4 h-0.5 w-16 bg-secondary"></div>
      </div>

      <div class="mb-12">
        <img src="/images/warehouse.jpg" alt="Ecopark Breda terrein met opslagfaciliteiten" loading="lazy" width="800" height="600" class="w-full h-56 object-cover rounded-sm" />
      </div>

      <div class="grid gap-px bg-border sm:grid-cols-2 lg:grid-cols-3">
        <div class="bg-white p-8">
          <span class="spec-label">Terrein</span>
          <p class="mt-2 text-lg font-bold text-dark">2,4 hectare volledig bestraat</p>
        </div>
        <div class="bg-white p-8">
          <span class="spec-label">Beveiliging</span>
          <p class="mt-2 text-lg font-bold text-dark">State-of-the-art camerasysteem</p>
        </div>
        <div class="bg-white p-8">
          <span class="spec-label">Capaciteit</span>
          <p class="mt-2 text-lg font-bold text-dark">180.000 ton jaarcapaciteit in overdekte loods</p>
        </div>
        <div class="bg-white p-8">
          <span class="spec-label">Certificering</span>
          <p class="mt-2 text-lg font-bold text-dark">VIHB geregistreerd</p>
        </div>
        <div class="bg-white p-8">
          <span class="spec-label">Toegang</span>
          <p class="mt-2 text-lg font-bold text-dark">Verplichte aan- en afmelding bij de portier</p>
        </div>
        <div class="bg-white p-8">
          <span class="spec-label">Nieuwbouw</span>
          <p class="mt-2 text-lg font-bold text-dark">Verouderde gebouwen plaatsgemaakt voor nieuwbouw</p>
        </div>
        <div class="bg-white p-8">
          <span class="spec-label">Gemeenten</span>
          <p class="mt-2 text-lg font-bold text-dark">Gemeente Breda & Gemeente Oosterhout</p>
        </div>
        <div class="bg-white p-8">
          <span class="spec-label">Dagelijks</span>
          <p class="mt-2 text-lg font-bold text-dark">50+ vrachtwagens aanvoer, 15 vrachtwagens afvoer</p>
        </div>
        <div class="bg-white p-8">
          <span class="spec-label">Duurzaamheid</span>
          <p class="mt-2 text-lg font-bold text-dark">Centraal bij inrichting gehele locatie</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Future Plans Section -->
  <section class="bg-white py-20 lg:py-28">
    <div class="border-t border-border"></div>
    <div class="mx-auto max-w-7xl px-4 pt-20 sm:px-6 lg:px-8">
      <div class="grid items-start gap-12 lg:grid-cols-2">
        <div>
          <span class="spec-label inline-block border border-primary px-3 py-1 mb-6">Binnenkort operationeel</span>
          <h2 class="text-3xl font-black text-dark sm:text-4xl">
            Binnenvaart Overslagfaciliteit
          </h2>
          <div class="mt-4 h-0.5 w-16 bg-secondary"></div>
          <p class="mt-6 text-lg leading-relaxed text-gray-medium">
            Ecopark Breda investeert in een eigen overslagfaciliteit voor transport per schip. Door directe overslag van vrachtwagen naar binnenschip verkorten wij de logistieke keten, verlagen wij transportkosten en dragen wij bij aan vermindering van CO2-uitstoot en wegcongestie in de regio Breda en West-Brabant. Duurzaamheid staat centraal bij de inrichting van de gehele locatie.
          </p>
        </div>
        <div class="lg:pt-4">
          <ul class="space-y-4 border-l-2 border-primary/20 pl-6">
            <li class="flex items-start gap-3">
              <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 bg-secondary"></span>
              <span class="text-dark/80">Minder wegverkeer en CO2-uitstoot</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 bg-secondary"></span>
              <span class="text-dark/80">Aansluiting op Brabants vaarwegennetwerk</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 bg-secondary"></span>
              <span class="text-dark/80">Lagere transportkosten per ton</span>
            </li>
          </ul>
          <a href="/contact/" class="mt-8 inline-flex items-center gap-2 border-2 border-secondary bg-secondary px-6 py-3 text-sm font-bold text-white transition-colors hover:bg-secondary-dark hover:border-secondary-dark">
            Vraag meer informatie aan
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTA />
</Layout>
