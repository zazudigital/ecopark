---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout title="Contact — Ecopark Breda | Bel 076-572 0030 of Vraag een Offerte Aan" description="Neem contact op met Ecopark Breda voor een vrijblijvende offerte. Bel 076-572 0030, mail ons of bezoek ons terrein aan de Nieuwe Bredase Baan 30 in Breda.">
  <!-- Hero -->
  <Hero
    title="Bel ons voor een vrijblijvende offerte"
    subtitle="Of het nu gaat om afvaloverslag, vrachtwagenstalling, containeropslag of bulkgoederenhandling — wij denken graag met u mee. Neem contact op en ontvang binnen 24 uur een voorstel afgestemd op uw situatie."
    showCta={false}
    compact={true}
  />

  <!-- Contact Section -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-black text-dark sm:text-3xl">Vraag een offerte aan of stel uw vraag</h2>
          <p class="mt-3 text-gray-medium">
            Vul het formulier in met uw gegevens en wensen. Wij nemen binnen een werkdag contact met u op voor een persoonlijk gesprek over de mogelijkheden.
          </p>

          <form class="mt-8 space-y-6" action="#" method="POST" id="contact-form">
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="naam" class="block text-sm font-bold text-dark">Naam *</label>
                <input
                  type="text"
                  id="naam"
                  name="naam"
                  required
                  class="mt-2 block w-full rounded-lg border border-gray-200 px-4 py-3 text-dark shadow-sm transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                  placeholder="Uw volledige naam"
                />
              </div>
              <div>
                <label for="bedrijf" class="block text-sm font-bold text-dark">Bedrijfsnaam</label>
                <input
                  type="text"
                  id="bedrijf"
                  name="bedrijf"
                  class="mt-2 block w-full rounded-lg border border-gray-200 px-4 py-3 text-dark shadow-sm transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                  placeholder="Uw bedrijfsnaam"
                />
              </div>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="email" class="block text-sm font-bold text-dark">E-mailadres *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="mt-2 block w-full rounded-lg border border-gray-200 px-4 py-3 text-dark shadow-sm transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                  placeholder="uw@email.nl"
                />
              </div>
              <div>
                <label for="telefoon" class="block text-sm font-bold text-dark">Telefoonnummer</label>
                <input
                  type="tel"
                  id="telefoon"
                  name="telefoon"
                  class="mt-2 block w-full rounded-lg border border-gray-200 px-4 py-3 text-dark shadow-sm transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                  placeholder="Uw telefoonnummer"
                />
              </div>
            </div>

            <div>
              <label for="dienst" class="block text-sm font-bold text-dark">Dienst</label>
              <select
                id="dienst"
                name="dienst"
                class="mt-2 block w-full rounded-lg border border-gray-200 px-4 py-3 text-dark shadow-sm transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              >
                <option value="">Waar kunnen wij u mee helpen?</option>
                <option value="afval-overslag">Afvaloverslag & verwerking</option>
                <option value="veilige-opslag">Vrachtwagenstalling & beveiligd parkeren</option>
                <option value="container-opslag">Containeropslag & beheer</option>
                <option value="bulk-materiaal">Bulkgoederenoverslag</option>
                <option value="beveiliging">24/7 Terreinbeveiliging</option>
                <option value="offerte">Vrijblijvende offerte aanvragen</option>
                <option value="anders">Overige vraag</option>
              </select>
            </div>

            <div>
              <label for="bericht" class="block text-sm font-bold text-dark">Bericht *</label>
              <textarea
                id="bericht"
                name="bericht"
                rows="5"
                required
                class="mt-2 block w-full rounded-lg border border-gray-200 px-4 py-3 text-dark shadow-sm transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                placeholder="Beschrijf uw situatie, gewenste dienst, geschatte volumes of stel uw vraag..."
              ></textarea>
            </div>

            <div>
              <button
                type="submit"
                class="inline-flex items-center gap-2 rounded-lg bg-primary px-8 py-4 text-base font-bold text-white shadow-lg transition-all duration-200 hover:bg-primary-dark hover:shadow-xl hover:-translate-y-0.5"
              >
                Verstuur bericht
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
                </svg>
              </button>
            </div>
          </form>

          <!-- Form success message (hidden by default) -->
          <div id="form-success" class="mt-6 hidden rounded-lg bg-secondary/10 p-6">
            <div class="flex items-start gap-3">
              <svg class="h-6 w-6 shrink-0 text-secondary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-bold text-dark">Bedankt voor uw bericht!</p>
                <p class="mt-1 text-sm text-gray-medium">Wij nemen binnen een werkdag contact met u op om uw aanvraag te bespreken.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Info Sidebar -->
        <div class="lg:col-span-2">
          <div class="space-y-6">
            <!-- Address Card -->
            <div class="rounded-2xl bg-gray-light p-8">
              <h3 class="mb-6 text-lg font-bold text-dark">Contactgegevens</h3>

              <ul class="space-y-5">
                <li class="flex items-start gap-4">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-bold text-dark">Adres</p>
                    <p class="mt-1 text-sm text-gray-medium">
                      Nieuwe Bredase Baan 30<br />
                      4825 BP Breda<br />
                      Nederland
                    </p>
                  </div>
                </li>

                <li class="flex items-start gap-4">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-bold text-dark">Telefoon</p>
                    <a href="tel:0765720030" class="mt-1 block text-sm text-primary hover:underline">076-572 0030</a>
                  </div>
                </li>

                <li class="flex items-start gap-4">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-bold text-dark">KvK-nummer</p>
                    <p class="mt-1 text-sm text-gray-medium">62609645</p>
                  </div>
                </li>
              </ul>
            </div>

            <!-- Opening Hours -->
            <div class="rounded-2xl bg-gray-light p-8">
              <h3 class="mb-6 text-lg font-bold text-dark">Openingstijden Terrein</h3>
              <ul class="space-y-3">
                <li class="flex items-center justify-between text-sm">
                  <span class="text-gray-medium">Maandag - Vrijdag</span>
                  <span class="font-bold text-dark">07:00 - 18:00</span>
                </li>
                <li class="flex items-center justify-between text-sm">
                  <span class="text-gray-medium">Zaterdag</span>
                  <span class="font-bold text-dark">Op afspraak</span>
                </li>
                <li class="flex items-center justify-between text-sm">
                  <span class="text-gray-medium">Zondag</span>
                  <span class="font-bold text-dark">Gesloten</span>
                </li>
              </ul>
              <div class="mt-6 flex items-center gap-2 rounded-lg bg-secondary/10 px-4 py-3">
                <svg class="h-5 w-5 text-secondary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
                <span class="text-sm font-bold text-secondary">Beveiliging 24/7 actief — ook buiten openingstijden</span>
              </div>
            </div>

            <!-- LinkedIn -->
            <a
              href="https://www.linkedin.com/company/ecopark-breda"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 rounded-2xl bg-primary p-6 text-white transition-all hover:bg-primary-dark hover:shadow-lg"
            >
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/10">
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </div>
              <div>
                <p class="font-bold">Volg Ecopark Breda op LinkedIn</p>
                <p class="text-sm text-white/70">Ontwikkelingen, uitbreidingen en sectorkennis</p>
              </div>
              <svg class="ml-auto h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="bg-gray-light py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <p class="mb-3 text-sm font-bold uppercase tracking-wider text-secondary">Locatie</p>
        <h2 class="text-3xl font-black tracking-tight text-dark sm:text-4xl">
          Strategisch gelegen, direct bereikbaar
        </h2>
        <p class="mt-4 text-lg text-gray-medium">
          Ons terrein aan de Nieuwe Bredase Baan 30 ligt op korte afstand van de op- en afritten van de A16 en A27, waardoor wij uitstekend bereikbaar zijn voor regionaal en nationaal vrachtverkeer.
        </p>
      </div>

      <!-- Map Embed -->
      <div class="overflow-hidden rounded-2xl shadow-xl">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2489.5!2d4.7738!3d51.5783!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c69f5a8b5f0001%3A0x0!2sNieuwe+Bredase+Baan+30%2C+4825+BP+Breda!5e0!3m2!1snl!2snl!4v1"
          width="100%"
          height="450"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Locatie Ecopark Breda op de kaart"
          class="w-full"
        ></iframe>
      </div>

      <!-- Directions -->
      <div class="mt-8 grid gap-6 sm:grid-cols-3">
        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>
          </div>
          <h3 class="font-bold text-dark">Per vrachtwagen</h3>
          <p class="mt-2 text-sm text-gray-medium">Direct bereikbaar via afslag Breda-Noord (A16). Brede toegangspoort en draairuimte voor vrachtwagens, opleggers en diepladers.</p>
        </div>
        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" /></svg>
          </div>
          <h3 class="font-bold text-dark">Knooppunt A16 & A27</h3>
          <p class="mt-2 text-sm text-gray-medium">Centrale ligging tussen Rotterdam, Antwerpen, Tilburg en Eindhoven. Ideaal voor regionale distributie en landelijk transport.</p>
        </div>
        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" /></svg>
          </div>
          <h3 class="font-bold text-dark">Routebeschrijving</h3>
          <p class="mt-2 text-sm text-gray-medium">Navigeer naar Nieuwe Bredase Baan 30, 4825 BP Breda. Ons terrein is duidelijk herkenbaar en bewegwijzerd.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMessage = document.getElementById('form-success');

  if (form && successMessage) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      // In production, this would send to a backend
      form.classList.add('hidden');
      successMessage.classList.remove('hidden');
    });
  }
</script>
