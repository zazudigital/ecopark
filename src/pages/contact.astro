---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout title="Contact Ecopark Breda | Bel 076-572 0030" description="Neem contact op met Ecopark Breda voor een vrijblijvende offerte. Bel 076-572 0030, mail ons of bezoek ons terrein aan de Nieuwe Bredase Baan 30 in Breda.">
  <!-- Hero -->
  <Hero
    title="Met de klant meedenken"
    subtitle="Of het nu gaat om gft, huishoudelijk afval, grof afval of bouw- en sloopafval — wij denken graag met u mee voor een oplossing op maat. Neem contact op en wij inventariseren samen uw situatie. Meer dan goed genoeg, dat is onze belofte."
    showCta={false}
    compact={true}
  />

  <!-- Contact Section -->
  <section class="bg-white py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <!-- Contact Form -->
        <div class="lg:col-span-3" data-animate>
          <h2 class="text-2xl font-black text-dark sm:text-3xl">Wij denken graag met u mee</h2>
          <div class="mt-3 h-0.5 w-16 bg-secondary"></div>
          <p class="mt-4 text-gray-medium">
            Vertel ons over uw situatie en wensen. Wij inventariseren uw behoeften en komen met een voorstel op maat — want met de klant meedenken, dat is hoe wij werken.
          </p>

          <!-- VIHB trust badge -->
          <div class="mt-4 inline-flex items-center gap-2 border border-primary/20 bg-primary/5 px-4 py-2">
            <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
            <span class="text-xs font-bold uppercase tracking-widest text-primary">VIHB Gecertificeerd</span>
          </div>

          <form class="mt-8 space-y-6" action="#" method="POST" id="contact-form">
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="naam" class="block text-sm font-bold text-dark">Naam *</label>
                <input
                  type="text"
                  id="naam"
                  name="naam"
                  required
                  class="mt-2 block w-full border border-border bg-light px-4 py-3 text-dark placeholder-gray-muted transition-colors focus:border-secondary focus:outline-none focus:ring-1 focus:ring-secondary"
                  placeholder="Uw volledige naam"
                />
              </div>
              <div>
                <label for="bedrijf" class="block text-sm font-bold text-dark">Bedrijfsnaam</label>
                <input
                  type="text"
                  id="bedrijf"
                  name="bedrijf"
                  class="mt-2 block w-full border border-border bg-light px-4 py-3 text-dark placeholder-gray-muted transition-colors focus:border-secondary focus:outline-none focus:ring-1 focus:ring-secondary"
                  placeholder="Uw bedrijfsnaam"
                />
              </div>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="email" class="block text-sm font-bold text-dark">E-mailadres *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="mt-2 block w-full border border-border bg-light px-4 py-3 text-dark placeholder-gray-muted transition-colors focus:border-secondary focus:outline-none focus:ring-1 focus:ring-secondary"
                  placeholder="uw@email.nl"
                />
              </div>
              <div>
                <label for="telefoon" class="block text-sm font-bold text-dark">Telefoonnummer</label>
                <input
                  type="tel"
                  id="telefoon"
                  name="telefoon"
                  class="mt-2 block w-full border border-border bg-light px-4 py-3 text-dark placeholder-gray-muted transition-colors focus:border-secondary focus:outline-none focus:ring-1 focus:ring-secondary"
                  placeholder="Uw telefoonnummer"
                />
              </div>
            </div>

            <div>
              <label for="dienst" class="block text-sm font-bold text-dark">Dienst</label>
              <select
                id="dienst"
                name="dienst"
                class="mt-2 block w-full border border-border bg-light px-4 py-3 text-dark transition-colors focus:border-secondary focus:outline-none focus:ring-1 focus:ring-secondary"
              >
                <option value="">Waar kunnen wij u mee helpen?</option>
                <option value="afval-overslag">Afvaloverslag & verwerking</option>
                <option value="veilige-opslag">Vrachtwagenstalling & beveiligd parkeren</option>
                <option value="container-opslag">Containeropslag & beheer</option>
                <option value="bulk-materiaal">Bulkgoederenoverslag</option>
                <option value="beveiliging">24/7 Terreinbeveiliging</option>
                <option value="offerte">Vrijblijvende offerte aanvragen</option>
                <option value="anders">Overige vraag</option>
              </select>
            </div>

            <div>
              <label for="bericht" class="block text-sm font-bold text-dark">Bericht *</label>
              <textarea
                id="bericht"
                name="bericht"
                rows="5"
                required
                class="mt-2 block w-full border border-border bg-light px-4 py-3 text-dark placeholder-gray-muted transition-colors focus:border-secondary focus:outline-none focus:ring-1 focus:ring-secondary"
                placeholder="Beschrijf uw situatie, gewenste dienst, geschatte volumes of stel uw vraag..."
              ></textarea>
            </div>

            <!-- Response promise -->
            <div class="flex items-center gap-2 text-sm text-gray-medium">
              <svg class="h-4 w-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>Wij reageren binnen 24 uur op werkdagen</span>
            </div>

            <div>
              <button
                type="submit"
                class="inline-flex items-center gap-2 border-2 border-secondary bg-secondary px-8 py-4 text-base font-bold text-white transition-colors duration-200 hover:bg-secondary-dark hover:border-secondary-dark"
              >
                Verstuur bericht
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
                </svg>
              </button>
            </div>
          </form>

          <!-- Form success message (hidden by default) -->
          <div id="form-success" class="mt-6 hidden border border-secondary/30 bg-secondary/10 p-6">
            <div class="flex items-start gap-3">
              <svg class="h-6 w-6 shrink-0 text-secondary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-bold text-dark">Bedankt voor uw bericht!</p>
                <p class="mt-1 text-sm text-gray-medium">Wij nemen binnen een werkdag contact met u op om uw aanvraag te bespreken.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Info Sidebar -->
        <div class="lg:col-span-2" data-animate>
          <div class="space-y-6">
            <!-- Address Card -->
            <div class="sidebar-card border border-border bg-light p-8">
              <h3 class="mb-6 text-lg font-bold text-dark">Contactgegevens</h3>

              <ul class="space-y-5">
                <li class="flex items-start gap-4">
                  <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
                  </svg>
                  <div>
                    <p class="font-bold text-dark">Adres</p>
                    <p class="mt-1 text-sm text-gray-medium">
                      Nieuwe Bredase Baan 30<br />
                      4825 BP Breda<br />
                      Bedrijventerrein De Krogten<br />
                      Nederland
                    </p>
                  </div>
                </li>

                <li class="flex items-start gap-4">
                  <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                  <div>
                    <p class="font-bold text-dark">Telefoon</p>
                    <a href="tel:0765720030" class="mt-1 block text-sm text-secondary hover:text-secondary-light">076 – 572 0030</a>
                  </div>
                </li>

                <li class="flex items-start gap-4">
                  <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
                  </svg>
                  <div>
                    <p class="font-bold text-dark">KvK-nummer</p>
                    <p class="mt-1 text-sm text-gray-medium">62609645</p>
                  </div>
                </li>
              </ul>
            </div>

            <!-- Opening Hours -->
            <div class="sidebar-card border border-border bg-light p-8">
              <div class="flex items-center gap-3 mb-6">
                <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <h3 class="text-lg font-bold text-dark">Openingstijden Terrein</h3>
              </div>
              <ul class="space-y-0">
                <li class="flex items-center justify-between border-b border-border py-3 text-sm">
                  <span class="text-gray-medium">Maandag - Vrijdag</span>
                  <span class="font-mono text-sm font-bold text-dark">07:00 - 18:00</span>
                </li>
                <li class="flex items-center justify-between border-b border-border py-3 text-sm">
                  <span class="text-gray-medium">Zaterdag</span>
                  <span class="font-bold text-dark">Op afspraak</span>
                </li>
                <li class="flex items-center justify-between py-3 text-sm">
                  <span class="text-gray-medium">Zondag</span>
                  <span class="font-bold text-dark">Gesloten</span>
                </li>
              </ul>
              <div class="mt-4 flex items-center gap-2 border border-secondary/20 bg-secondary/5 px-4 py-3">
                <span class="block h-2 w-2 animate-pulse bg-secondary rounded-full"></span>
                <span class="text-sm font-bold text-secondary-dark">Beveiliging 24/7 actief — ook buiten openingstijden</span>
              </div>
            </div>

            <!-- LinkedIn -->
            <a
              href="https://www.linkedin.com/company/ecopark-breda"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 border border-border bg-light p-6 text-dark transition-all hover:border-primary/30"
            >
              <div class="flex h-10 w-10 items-center justify-center border border-border bg-white">
                <svg class="h-5 w-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </div>
              <div>
                <p class="font-bold">Volg Ecopark Breda op LinkedIn</p>
                <p class="text-sm text-gray-medium">Ontwikkelingen, uitbreidingen en sectorkennis</p>
              </div>
              <svg class="ml-auto h-5 w-5 text-gray-muted" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="bg-light py-20 lg:py-28">
    <div class="border-t border-border"></div>
    <div class="mx-auto max-w-7xl px-4 pt-20 sm:px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-2xl text-center" data-animate>
        <p class="spec-label mb-3">Locatie</p>
        <h2 class="text-3xl font-black tracking-tight text-dark sm:text-4xl">
          Eenvoudig bereikbaar voor alle vrachtvervoer
        </h2>
        <p class="mt-4 text-lg text-gray-medium">
          Ecopark Breda ligt op bedrijventerrein De Krogten, aan de rand van Breda en aan de rivier de Mark. Ons 2,4 hectare grote, volledig bestraatte terrein is eenvoudig bereikbaar via de snelwegen A16, A59 en A27. Wij bedienen dagelijks Gemeente Breda, Gemeente Oosterhout en het bedrijfsleven.
        </p>
      </div>

      <!-- Map Embed -->
      <div class="overflow-hidden border border-border">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2489.5!2d4.7738!3d51.5783!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c69f5a8b5f0001%3A0x0!2sNieuwe+Bredase+Baan+30%2C+4825+BP+Breda!5e0!3m2!1snl!2snl!4v1"
          width="100%"
          height="450"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Locatie Ecopark Breda op de kaart"
          class="w-full"
        ></iframe>
      </div>

      <!-- Directions -->
      <div class="mt-8 grid gap-px bg-border sm:grid-cols-3">
        <div class="bg-white p-6">
          <span class="spec-label">Per vrachtwagen</span>
          <p class="mt-2 text-sm text-gray-medium">Direct bereikbaar via afslag Breda-Noord (A16). Brede toegangspoort en draairuimte voor vrachtwagens, opleggers en diepladers.</p>
        </div>
        <div class="bg-white p-6">
          <span class="spec-label">Drie snelwegen</span>
          <p class="mt-2 text-sm text-gray-medium">Vlakbij de A16, A59 en A27 — centrale ligging tussen Rotterdam, Antwerpen, Tilburg en Eindhoven. Ideaal voor regionale distributie en landelijk transport.</p>
        </div>
        <div class="bg-white p-6">
          <span class="spec-label">Aan het water</span>
          <p class="mt-2 text-sm text-gray-medium">Gelegen aan de rivier de Mark. Via het Volkerak en Hollandsdiep komt het industriegebied Moerdijk per binnenschip binnen handbereik.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMessage = document.getElementById('form-success');

  if (form && successMessage) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      // In production, this would send to a backend
      form.classList.add('hidden');
      successMessage.classList.remove('hidden');
    });
  }
</script>
