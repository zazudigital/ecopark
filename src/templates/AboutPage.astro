---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';
import { useTranslations, localePath, type Locale } from '../i18n';

const locale = (Astro.currentLocale || 'nl') as Locale;
const t = useTranslations(locale);

const paragraphs = t('overOns.philosophy.paragraphs') as Array<string>;
const whyUsItems = t('overOns.whyUs.items') as Array<{ number: string; title: string; description: string }>;
const charityParagraphs = t('overOns.charity.paragraphs') as Array<string>;
const companyFields = t('overOns.companyDetails.fields') as Array<{ label: string; value: string; isPhone?: boolean }>;
---

<Layout
  title={t('overOns.meta.title')}
  description={t('overOns.meta.description')}
  schema={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": t('nav.home'), "item": `https://ecoparkbreda.nl${localePath(locale, '/')}` },
      { "@type": "ListItem", "position": 2, "name": t('nav.overOns'), "item": `https://ecoparkbreda.nl${localePath(locale, '/over-ons/')}` }
    ]
  }}
>
  <!-- Hero -->
  <Hero
    title={t('overOns.hero.title')}
    subtitle={t('overOns.hero.subtitle')}
    showCta={false}
    compact={true}
  />

  <!-- Philosophy Section -->
  <section class="bg-white py-20 lg:py-28" aria-labelledby="philosophy-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-16">
        <div data-animate="fade-up">
          <p class="spec-label mb-3">{t('overOns.philosophy.label')}</p>
          <h2 id="philosophy-heading" class="text-3xl font-black tracking-tight text-dark text-balance sm:text-4xl">
            {t('overOns.philosophy.heading')}
          </h2>
          <div class="mt-4 h-0.5 w-16 bg-secondary"></div>
          {paragraphs.map((paragraph) => (
            <p class="mt-6 text-lg leading-relaxed text-gray-medium max-w-prose">
              {paragraph}
            </p>
          ))}
        </div>

        <!-- Image and quote block -->
        <div class="space-y-8 lg:mt-16" data-animate="fade-left">
          <img src="/images/trucks.jpg" alt={t('overOns.philosophy.trucksAlt')} loading="lazy" decoding="async" width="800" height="600" class="w-full h-56 object-cover object-center" style="aspect-ratio: 800/600;" />
          <div class="border-l-2 border-primary pl-8">
            <blockquote class="text-3xl font-black italic text-dark text-balance lg:text-4xl">
              {t('overOns.philosophy.quote')}
            </blockquote>
            <div class="mt-6 h-px w-12 bg-border"></div>
            <p class="mt-4 font-bold text-gray-medium">{t('overOns.philosophy.quoteAttribution')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Company Info -->
  <section class="bg-light tech-grid-bg py-24 lg:py-32" aria-labelledby="why-us-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-2xl text-center lg:mb-16" data-animate="fade-up">
        <p class="spec-label mb-3">{t('overOns.whyUs.label')}</p>
        <h2 id="why-us-heading" class="text-3xl font-black tracking-tight text-dark text-balance sm:text-4xl">
          {t('overOns.whyUs.heading')}
        </h2>
        <p class="mt-4 text-lg text-gray-medium max-w-prose mx-auto">
          {t('overOns.whyUs.description')}
        </p>
      </div>

      <div class="grid gap-px bg-border md:grid-cols-3" data-animate-stagger>
        {whyUsItems.map((item) => (
          <div class="bg-white p-8 min-w-0">
            <span class="spec-label">{item.number}</span>
            <h3 class="mt-4 mb-3 text-xl font-bold text-dark text-balance break-words">{item.title}</h3>
            <p class="text-base text-gray-medium leading-relaxed line-clamp-4">
              {item.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Charity Section -->
  <section class="bg-white py-20 lg:py-28" aria-labelledby="charity-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-16">
        <!-- Text -->
        <div data-animate="fade-up">
          <span class="spec-label inline-block border border-primary px-3 py-1 mb-6">{t('overOns.charity.label')}</span>
          <h2 id="charity-heading" class="text-3xl font-black text-dark text-balance sm:text-4xl">
            {t('overOns.charity.heading')}
          </h2>
          <div class="mt-4 h-0.5 w-16 bg-secondary"></div>
          {charityParagraphs.map((paragraph) => (
            <p class="mt-6 text-lg leading-relaxed text-gray-medium max-w-prose">
              {paragraph}
            </p>
          ))}
          <a
            href="https://www.prithipura.org"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-10 inline-flex items-center gap-2 border-2 border-secondary bg-secondary px-6 py-3 text-base font-bold text-white transition-all duration-200 hover:bg-secondary-dark hover:border-secondary-dark hover:shadow-md hover:-translate-y-px active:translate-y-0"
          >
            {t('overOns.charity.linkText')}
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
          </a>
        </div>

        <!-- Visual -->
        <div class="border-l-2 border-primary/20 pl-8 lg:mt-8" data-animate="scale-in">
          <span class="stat-number text-6xl text-primary lg:text-8xl">{t('overOns.charity.statValue')}</span>
          <p class="mt-2 text-base font-bold uppercase tracking-wider text-gray-medium">{t('overOns.charity.statLabel')}</p>
          <div class="mt-8 h-px w-full bg-border"></div>
          <p class="mt-6 text-xl font-black italic text-dark/70 text-balance">{t('overOns.charity.tagline')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Company Details -->
  <section class="bg-light py-20 lg:py-28" aria-labelledby="company-details-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl" data-animate="fade-up">
        <h2 id="company-details-heading" class="mb-10 text-center text-3xl font-black tracking-tight text-dark text-balance sm:text-4xl lg:mb-12">
          {t('overOns.companyDetails.heading')}
        </h2>

        <div class="border border-border bg-white">
          <dl class="divide-y divide-border">
            {companyFields.map((field) => (
              <div class="spec-row grid grid-cols-1 gap-1 px-6 py-5 sm:grid-cols-3 sm:gap-4 sm:px-8 min-w-0">
                <dt class="spec-label flex items-center">{field.label}</dt>
                <dd class="text-base text-dark sm:col-span-2 break-words">
                  {field.isPhone ? (
                    <a href="tel:+31765720030" class="font-bold text-secondary-dark transition-colors duration-200 hover:text-dark">{field.value}</a>
                  ) : (
                    field.value
                  )}
                </dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA />
</Layout>
