---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { useTranslations, localePath, type Locale } from '../i18n';

const locale = (Astro.currentLocale || 'nl') as Locale;
const t = useTranslations(locale);

const serviceOptions = t('contact.form.serviceOptions') as Array<{ value: string; label: string }>;
const directions = t('contact.map.directions') as Array<{ label: string; description: string }>;
---

<Layout
  title={t('contact.meta.title')}
  description={t('contact.meta.description')}
  schema={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": t('nav.home'), "item": `https://ecoparkbreda.nl${localePath(locale, '/')}` },
      { "@type": "ListItem", "position": 2, "name": t('nav.contact'), "item": `https://ecoparkbreda.nl${localePath(locale, '/contact/')}` }
    ]
  }}
>
  <!-- Hero -->
  <Hero
    title={t('contact.hero.title')}
    subtitle={t('contact.hero.subtitle')}
    showCta={false}
    compact={true}
  />

  <!-- Contact Section -->
  <section class="bg-white py-20 lg:py-28" aria-labelledby="contact-form-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5 lg:gap-16">
        <!-- Contact Form -->
        <div class="lg:col-span-3 min-w-0" data-animate="fade-up">
          <h2 id="contact-form-heading" class="text-2xl font-black text-dark text-balance sm:text-3xl">{t('contact.form.heading')}</h2>
          <div class="mt-3 h-0.5 w-16 bg-secondary"></div>
          <p class="mt-4 text-base text-gray-medium max-w-prose">
            {t('contact.form.description')}
          </p>

          <!-- VIHB trust badge -->
          <div class="mt-4 inline-flex items-center gap-2 border border-primary/20 bg-primary/5 px-4 py-2">
            <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
            <span class="text-xs font-bold uppercase tracking-widest text-primary">{t('contact.form.vihbBadge')}</span>
          </div>

          <form class="mt-8 space-y-6" action="#" method="POST" id="contact-form" novalidate>
            <p class="text-sm font-medium text-gray-medium"><span class="text-red-600 font-bold" aria-hidden="true">*</span> = {t('formErrors.requiredIndicator')}</p>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="naam" class="block text-base font-bold text-dark">{t('contact.form.nameLabel')} <span class="text-red-600" aria-hidden="true">*</span></label>
                <input
                  type="text"
                  id="naam"
                  name="naam"
                  required
                  aria-required="true"
                  aria-describedby="naam-error"
                  maxlength="100"
                  autocomplete="name"
                  class="mt-2 block w-full border border-border bg-light px-4 py-3 text-dark placeholder-gray-muted transition-colors focus:border-secondary focus:outline-none focus:ring-1 focus:ring-secondary"
                  placeholder={t('contact.form.namePlaceholder')}
                />
                <p id="naam-error" class="mt-1.5 hidden text-sm font-bold text-red-600" role="alert">{t('formErrors.required')}</p>
              </div>
              <div>
                <label for="bedrijf" class="block text-base font-bold text-dark">{t('contact.form.companyLabel')}</label>
                <input
                  type="text"
                  id="bedrijf"
                  name="bedrijf"
                  maxlength="100"
                  autocomplete="organization"
                  class="mt-2 block w-full border border-border bg-light px-4 py-3 text-dark placeholder-gray-muted transition-colors focus:border-secondary focus:outline-none focus:ring-1 focus:ring-secondary"
                  placeholder={t('contact.form.companyPlaceholder')}
                />
              </div>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="email" class="block text-base font-bold text-dark">{t('contact.form.emailLabel')} <span class="text-red-600" aria-hidden="true">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  aria-required="true"
                  aria-describedby="email-error"
                  maxlength="254"
                  autocomplete="email"
                  inputmode="email"
                  class="mt-2 block w-full border border-border bg-light px-4 py-3 text-dark placeholder-gray-muted transition-colors focus:border-secondary focus:outline-none focus:ring-1 focus:ring-secondary"
                  placeholder={t('contact.form.emailPlaceholder')}
                />
                <p id="email-error" class="mt-1.5 hidden text-sm font-bold text-red-600" role="alert">{t('formErrors.invalidEmail')}</p>
              </div>
              <div>
                <label for="telefoon" class="block text-base font-bold text-dark">{t('contact.form.phoneLabel')}</label>
                <input
                  type="tel"
                  id="telefoon"
                  name="telefoon"
                  maxlength="20"
                  autocomplete="tel"
                  inputmode="tel"
                  class="mt-2 block w-full border border-border bg-light px-4 py-3 text-dark placeholder-gray-muted transition-colors focus:border-secondary focus:outline-none focus:ring-1 focus:ring-secondary"
                  placeholder={t('contact.form.phonePlaceholder')}
                />
              </div>
            </div>

            <div>
              <label for="dienst" class="block text-base font-bold text-dark">{t('contact.form.serviceLabel')}</label>
              <select
                id="dienst"
                name="dienst"
                class="mt-2 block w-full border border-border bg-light px-4 py-3 text-dark transition-colors focus:border-secondary focus:outline-none focus:ring-1 focus:ring-secondary"
              >
                <option value="">{t('contact.form.servicePlaceholder')}</option>
                {serviceOptions.map((option) => (
                  <option value={option.value}>{option.label}</option>
                ))}
              </select>
            </div>

            <div>
              <label for="bericht" class="block text-base font-bold text-dark">{t('contact.form.messageLabel')} <span class="text-red-600" aria-hidden="true">*</span></label>
              <textarea
                id="bericht"
                name="bericht"
                rows="5"
                required
                aria-required="true"
                aria-describedby="bericht-error"
                maxlength="2000"
                class="mt-2 block w-full border border-border bg-light px-4 py-3 text-dark placeholder-gray-muted transition-colors focus:border-secondary focus:outline-none focus:ring-1 focus:ring-secondary"
                placeholder={t('contact.form.messagePlaceholder')}
              ></textarea>
              <p id="bericht-error" class="mt-1.5 hidden text-sm font-bold text-red-600" role="alert">{t('formErrors.required')}</p>
            </div>

            <!-- Response promise -->
            <div class="flex items-center gap-2 text-base text-gray-medium">
              <svg class="h-4 w-4 shrink-0 text-secondary-dark" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>{t('contact.form.responsePromise')}</span>
            </div>

            <div>
              <button
                type="submit"
                id="submit-btn"
                data-loading-text={t('contact.form.submitting')}
                class="inline-flex items-center gap-2 border-2 border-secondary bg-secondary px-8 py-4 text-base font-bold text-white transition-all duration-200 hover:bg-secondary-dark hover:border-secondary-dark hover:shadow-md hover:-translate-y-px active:translate-y-0 disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none disabled:shadow-none"
              >
                <span id="submit-text">{t('contact.form.submitButton')}</span>
                <svg id="submit-icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
                </svg>
                <svg id="submit-spinner" class="hidden h-5 w-5 animate-spin" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
                </svg>
              </button>
            </div>
          </form>

          <!-- Form success message (hidden by default) -->
          <div id="form-success" class="mt-6 hidden border border-secondary/30 bg-secondary/10 p-6" role="alert" tabindex="-1">
            <div class="flex items-start gap-3">
              <svg class="h-6 w-6 shrink-0 text-secondary-dark" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-bold text-dark">{t('contact.form.successTitle')}</p>
                <p class="mt-1 text-base text-gray-medium">{t('contact.form.successMessage')}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Info Sidebar -->
        <div class="lg:col-span-2 min-w-0" data-animate="fade-left">
          <div class="space-y-6">
            <!-- Address Card -->
            <div class="sidebar-card border border-border bg-light p-6 sm:p-8">
              <h3 class="mb-6 text-lg font-bold text-dark">{t('contact.sidebar.contactHeading')}</h3>

              <ul class="space-y-5">
                <li class="flex items-start gap-4">
                  <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
                  </svg>
                  <div class="min-w-0">
                    <p class="font-bold text-dark">{t('contact.sidebar.addressLabel')}</p>
                    <address class="mt-1 text-base text-gray-medium not-italic">
                      {t('contact.sidebar.addressLine1')}<br />
                      {t('contact.sidebar.addressLine2')}<br />
                      {t('contact.sidebar.addressLine3')}<br />
                      {t('contact.sidebar.addressLine4')}
                    </address>
                  </div>
                </li>

                <li class="flex items-start gap-4">
                  <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                  <div>
                    <p class="font-bold text-dark">{t('contact.sidebar.phoneLabel')}</p>
                    <a href="tel:+31765720030" class="mt-1 block text-base font-bold text-secondary-dark transition-colors duration-200 hover:text-dark">076 – 572 0030</a>
                  </div>
                </li>

                <li class="flex items-start gap-4">
                  <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
                  </svg>
                  <div>
                    <p class="font-bold text-dark">{t('contact.sidebar.kvkLabel')}</p>
                    <p class="mt-1 text-base text-gray-medium">62609645</p>
                  </div>
                </li>
              </ul>
            </div>

            <!-- Opening Hours -->
            <div class="sidebar-card border border-border bg-light p-6 sm:p-8">
              <div class="flex items-center gap-3 mb-6">
                <svg class="h-5 w-5 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <h3 class="text-lg font-bold text-dark">{t('contact.sidebar.hoursHeading')}</h3>
              </div>
              <ul class="space-y-0">
                <li class="flex items-center justify-between gap-4 border-b border-border py-3 text-base min-w-0">
                  <span class="text-gray-medium">{t('contact.sidebar.monFri')}</span>
                  <span class="font-mono text-base font-bold text-dark shrink-0">{t('contact.sidebar.monFriValue')}</span>
                </li>
                <li class="flex items-center justify-between gap-4 border-b border-border py-3 text-base min-w-0">
                  <span class="text-gray-medium">{t('contact.sidebar.saturday')}</span>
                  <span class="font-bold text-dark shrink-0">{t('contact.sidebar.saturdayValue')}</span>
                </li>
                <li class="flex items-center justify-between gap-4 py-3 text-base min-w-0">
                  <span class="text-gray-medium">{t('contact.sidebar.sunday')}</span>
                  <span class="font-bold text-dark shrink-0">{t('contact.sidebar.sundayValue')}</span>
                </li>
              </ul>
              <div class="mt-4 flex items-center gap-2 border border-secondary/20 bg-secondary/5 px-4 py-3">
                <span class="block h-2 w-2 shrink-0 animate-pulse bg-secondary rounded-full" aria-hidden="true"></span>
                <span class="text-base font-bold text-secondary-dark">{t('contact.sidebar.securityNote')}</span>
              </div>
            </div>

            <!-- LinkedIn -->
            <a
              href="https://www.linkedin.com/company/ecopark-breda"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 border border-border bg-light p-6 text-dark transition-all duration-200 hover:border-primary/30 hover:shadow-sm"
              aria-label="Ecopark Breda on LinkedIn"
            >
              <div class="flex h-10 w-10 shrink-0 items-center justify-center border border-border bg-white">
                <svg class="h-5 w-5 text-primary" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </div>
              <div class="min-w-0">
                <p class="font-bold">{t('contact.sidebar.linkedinTitle')}</p>
                <p class="text-base text-gray-medium">{t('contact.sidebar.linkedinSubtitle')}</p>
              </div>
              <svg class="ml-auto h-5 w-5 shrink-0 text-gray-muted" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="bg-light py-24 lg:py-32" aria-labelledby="map-heading">
    <div class="border-t border-border"></div>
    <div class="mx-auto max-w-7xl px-4 pt-16 sm:px-6 lg:px-8 lg:pt-20">
      <div class="mx-auto mb-12 max-w-2xl text-center" data-animate="fade-up">
        <p class="spec-label mb-3">{t('contact.map.label')}</p>
        <h2 id="map-heading" class="text-3xl font-black tracking-tight text-dark text-balance sm:text-4xl">
          {t('contact.map.heading')}
        </h2>
        <p class="mt-4 text-lg text-gray-medium max-w-prose mx-auto">
          {t('contact.map.description')}
        </p>
      </div>

      <!-- Map Embed -->
      <div class="overflow-hidden border border-border" style="aspect-ratio: 16/9;">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2489.5!2d4.7738!3d51.5783!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c69f5a8b5f0001%3A0x0!2sNieuwe+Bredase+Baan+30%2C+4825+BP+Breda!5e0!3m2!1snl!2snl!4v1"
          width="100%"
          height="450"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={t('contact.map.mapTitle')}
          class="w-full h-full"
        ></iframe>
      </div>

      <!-- Directions -->
      <div class="mt-10 grid gap-px bg-border sm:grid-cols-3" data-animate-stagger>
        {directions.map((direction) => (
          <div class="bg-white p-6 min-w-0">
            <span class="spec-label">{direction.label}</span>
            <p class="mt-2 text-base font-medium text-gray-medium">{direction.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMessage = document.getElementById('form-success');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitText = document.getElementById('submit-text');
  const submitIcon = document.getElementById('submit-icon');
  const submitSpinner = document.getElementById('submit-spinner');
  let isSubmitting = false;

  function showError(id: string) {
    const el = document.getElementById(id + '-error');
    const input = document.getElementById(id);
    if (el) el.classList.remove('hidden');
    if (input) {
      input.classList.add('border-red-500');
      input.setAttribute('aria-invalid', 'true');
    }
  }

  function clearError(id: string) {
    const el = document.getElementById(id + '-error');
    const input = document.getElementById(id);
    if (el) el.classList.add('hidden');
    if (input) {
      input.classList.remove('border-red-500');
      input.removeAttribute('aria-invalid');
    }
  }

  function validateForm(): boolean {
    let valid = true;
    const naam = (document.getElementById('naam') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const bericht = (document.getElementById('bericht') as HTMLTextAreaElement).value.trim();

    clearError('naam');
    clearError('email');
    clearError('bericht');

    if (!naam) { showError('naam'); valid = false; }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showError('email'); valid = false; }
    if (!bericht) { showError('bericht'); valid = false; }

    // Focus the first invalid field
    if (!valid) {
      const firstInvalid = form.querySelector('[aria-invalid="true"]') as HTMLElement;
      if (firstInvalid) firstInvalid.focus();
    }

    return valid;
  }

  // Clear errors on input
  ['naam', 'email', 'bericht'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('input', () => clearError(id));
  });

  if (form && successMessage && submitBtn) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();

      if (!validateForm()) return;

      // Prevent double submit
      if (isSubmitting) return;
      isSubmitting = true;

      // Show loading state
      submitBtn.disabled = true;
      submitBtn.setAttribute('aria-busy', 'true');
      if (submitText) submitText.textContent = submitBtn.dataset.loadingText || 'Verzenden...';
      if (submitIcon) submitIcon.classList.add('hidden');
      if (submitSpinner) submitSpinner.classList.remove('hidden');

      // Simulate send (replace with real backend in production)
      setTimeout(() => {
        form.classList.add('hidden');
        successMessage.classList.remove('hidden');
        successMessage.focus();
      }, 800);
    });
  }
</script>
