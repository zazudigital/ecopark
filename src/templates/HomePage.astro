---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTA from '../components/CTA.astro';
import { useTranslations, localePath, type Locale } from '../i18n';

const locale = (Astro.currentLocale || 'nl') as Locale;
const t = useTranslations(locale);

const services = t('home.services.items') as Array<{ number: string; title: string; description: string }>;
const specs = t('home.facility.specs') as Array<{ label: string; value: string }>;
const benefits = t('home.future.benefits') as Array<string>;
---

<Layout
  title={t('home.meta.title')}
  description={t('home.meta.description')}
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Ecopark Breda B.V.",
      "description": t('home.meta.description'),
      "url": "https://ecoparkbreda.nl",
      "telephone": "+31765720030",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Nieuwe Bredase Baan 30",
        "addressLocality": "Breda",
        "postalCode": "4825 BP",
        "addressCountry": "NL"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 51.5783,
        "longitude": 4.7738
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "07:00",
          "closes": "18:00"
        }
      ],
      "sameAs": ["https://www.linkedin.com/company/ecopark-breda"]
    },
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Ecopark Breda",
      "url": "https://ecoparkbreda.nl",
      "inLanguage": ["nl", "en", "de"]
    }
  ]}
>
  <!-- Hero Section with Stats integrated -->
  <Hero
    title={t('home.hero.title')}
    subtitle={t('home.hero.subtitle')}
    showStats={true}
  />

  <!-- Quick value summary — what we do in 3 seconds -->
  <section class="bg-white py-12 lg:py-16" aria-label="Quick overview">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-px bg-border sm:grid-cols-3 border border-border" data-animate-stagger>
        <div class="bg-white p-6 lg:p-8">
          <span class="spec-label text-secondary-dark">{t('home.quickSummary.item1Label')}</span>
          <p class="mt-2 text-lg font-bold text-dark">{t('home.quickSummary.item1')}</p>
        </div>
        <div class="bg-white p-6 lg:p-8">
          <span class="spec-label text-secondary-dark">{t('home.quickSummary.item2Label')}</span>
          <p class="mt-2 text-lg font-bold text-dark">{t('home.quickSummary.item2')}</p>
        </div>
        <div class="bg-white p-6 lg:p-8">
          <span class="spec-label text-secondary-dark">{t('home.quickSummary.item3Label')}</span>
          <p class="mt-2 text-lg font-bold text-dark">{t('home.quickSummary.item3')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section — Industrial grid -->
  <section class="bg-light py-20 lg:py-28" id="diensten" aria-labelledby="services-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl lg:mb-16" data-animate="fade-up">
        <p class="spec-label mb-3">{t('home.services.label')}</p>
        <h2 id="services-heading" class="text-h1 font-black tracking-tight text-dark text-balance">
          {t('home.services.heading')}
        </h2>
        <p class="mt-4 text-lg text-gray-medium max-w-prose">
          {t('home.services.description')}
        </p>
      </div>

      <div data-animate-stagger>
        {services.map((service) => (
          <a href={localePath(locale, '/diensten/')} class="block">
            <ServiceCard
              number={service.number}
              title={service.title}
              description={service.description}
            />
          </a>
        ))}
      </div>

      <div class="mt-12 text-center" data-animate="fade-up">
        <a href={localePath(locale, '/diensten/')} class="btn inline-flex items-center gap-2 border-2 border-primary bg-primary px-8 py-4 text-base font-bold text-white transition-all duration-200 hover:bg-primary-dark hover:border-primary-dark hover:shadow-md">
          {t('home.services.viewAll')}
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Facility Section — Technical blueprint aesthetic -->
  <section class="bg-dark text-white py-24 lg:py-32 relative overflow-hidden" aria-labelledby="facility-heading">
    <!-- Blueprint grid background -->
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(rgba(57,181,74,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(57,181,74,0.5) 1px, transparent 1px); background-size: 32px 32px;" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
        <!-- Left: heading + image -->
        <div class="lg:col-span-5" data-animate="fade-up">
          <p class="spec-label mb-3" style="color: rgba(57,181,74,0.8);">{t('home.facility.label')}</p>
          <h2 id="facility-heading" class="text-h1 font-black tracking-tight text-white text-balance">
            {t('home.facility.heading')}
          </h2>
          <div class="mt-4 h-0.5 w-24 bg-secondary"></div>
          <p class="mt-6 text-lg text-white/70 font-bold max-w-prose">
            {t('home.facility.description')}
          </p>
          <div class="mt-10">
            <img src="/images/warehouse.jpg" alt={t('home.facility.warehouseAlt')} loading="lazy" decoding="async" width="800" height="600" class="w-full h-56 object-cover object-center border border-white/10" style="aspect-ratio: 800/600;" />
          </div>
        </div>
        <!-- Right: spec grid -->
        <div class="lg:col-span-7" data-animate="fade-left">
          <div class="grid gap-px bg-white/10 sm:grid-cols-2" data-animate-stagger="scale">
            {specs.map((spec, idx) => (
              <div class:list={["p-6 lg:p-8 min-w-0 transition-all duration-200 hover:bg-white/10", idx === 0 ? "bg-white/[0.07] border-l-2 border-secondary" : "bg-white/[0.04]"]}>
                <span class="spec-label text-xs" style="color: rgba(57,181,74,0.7);">{spec.label}</span>
                <p class="mt-2 text-base font-bold text-white/90 break-words">{spec.value}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Future Plans Section -->
  <section class="bg-white py-20 lg:py-28" aria-labelledby="future-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-16">
        <div data-animate="blur-in">
          <span class="spec-label inline-block border border-secondary bg-secondary/5 px-3 py-1 mb-6 text-secondary-dark">{t('home.future.badge')}</span>
          <h2 id="future-heading" class="text-h1 font-black text-dark text-balance">
            {t('home.future.heading')}
          </h2>
          <div class="mt-4 h-0.5 w-16 bg-secondary"></div>
          <p class="mt-6 text-lg leading-relaxed text-gray-medium max-w-prose">
            {t('home.future.description')}
          </p>
        </div>
        <div class="lg:pt-4" data-animate="fade-left">
          <ul class="space-y-5 border-l-2 border-primary/20 pl-6">
            {benefits.map((benefit) => (
              <li class="flex items-start gap-3 min-w-0">
                <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 bg-secondary" aria-hidden="true"></span>
                <span class="text-base font-bold text-dark/80">{benefit}</span>
              </li>
            ))}
          </ul>
          <a href={localePath(locale, '/contact/')} class="btn mt-10 inline-flex items-center gap-2 border-2 border-secondary bg-secondary px-8 py-4 text-base font-bold text-white transition-all duration-200 hover:bg-secondary-dark hover:border-secondary-dark hover:shadow-md">
            {t('home.future.ctaButton')}
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTA />
</Layout>
