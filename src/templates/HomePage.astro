---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTA from '../components/CTA.astro';
import { useTranslations, localePath, type Locale } from '../i18n';

const locale = (Astro.currentLocale || 'nl') as Locale;
const t = useTranslations(locale);

const services = t('home.services.items') as Array<{ number: string; title: string; description: string }>;
const specs = t('home.facility.specs') as Array<{ label: string; value: string }>;
const benefits = t('home.future.benefits') as Array<string>;
---

<Layout
  title={t('home.meta.title')}
  description={t('home.meta.description')}
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Ecopark Breda B.V.",
      "description": t('home.meta.description'),
      "url": "https://ecoparkbreda.nl",
      "telephone": "+31765720030",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Nieuwe Bredase Baan 30",
        "addressLocality": "Breda",
        "postalCode": "4825 BP",
        "addressCountry": "NL"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 51.5783,
        "longitude": 4.7738
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "07:00",
          "closes": "18:00"
        }
      ],
      "sameAs": ["https://www.linkedin.com/company/ecopark-breda"]
    },
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Ecopark Breda",
      "url": "https://ecoparkbreda.nl",
      "inLanguage": ["nl", "en", "de"]
    }
  ]}
>
  <!-- Hero Section with Stats integrated -->
  <Hero
    title={t('home.hero.title')}
    subtitle={t('home.hero.subtitle')}
    showStats={true}
  />

  <!-- Certification Bar -->
  <div class="bg-dark py-6" data-animate="fade-up">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-8 lg:gap-12 text-white/80 text-base font-bold">
        <span class="flex items-center gap-2"><span class="text-secondary font-bold text-lg">VIHB</span> {t('certBar.vihb')}</span>
        <span class="hidden w-px h-4 bg-white/20 sm:block" aria-hidden="true"></span>
        <span class="flex items-center gap-2"><span class="text-secondary font-bold text-lg">ISO</span> {t('certBar.iso')}</span>
        <span class="hidden w-px h-4 bg-white/20 sm:block" aria-hidden="true"></span>
        <span class="flex items-center gap-2"><span class="text-secondary font-bold text-lg">24/7</span> {t('certBar.security')}</span>
      </div>
    </div>
  </div>

  <!-- Section divider with green accent -->
  <div class="relative">
    <hr class="section-hr" />
    <div class="absolute left-0 top-0 h-0.5 w-16 bg-secondary"></div>
  </div>

  <!-- Services Section — Alternating full-width rows -->
  <section class="bg-white py-20 lg:py-28" id="diensten" aria-labelledby="services-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl lg:mb-16" data-animate="fade-up">
        <p class="spec-label mb-3">{t('home.services.label')}</p>
        <h2 id="services-heading" class="text-3xl font-black tracking-tight text-dark text-balance sm:text-4xl">
          {t('home.services.heading')}
        </h2>
        <p class="mt-4 text-lg text-gray-medium max-w-prose">
          {t('home.services.description')}
        </p>
      </div>

      <div class="mb-12" data-animate="fade-up">
        <img src="/images/trucks.jpg" alt={t('home.services.trucksAlt')} loading="lazy" decoding="async" width="800" height="600" class="w-full h-64 object-cover object-center" style="aspect-ratio: 800/600;" />
      </div>

      <div data-animate-stagger>
        {services.map((service) => (
          <a href={localePath(locale, '/diensten/')} class="block">
            <ServiceCard
              number={service.number}
              title={service.title}
              description={service.description}
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Section divider with green accent -->
  <div class="relative">
    <hr class="section-hr" />
    <div class="absolute left-0 top-0 h-0.5 w-16 bg-secondary"></div>
  </div>

  <!-- Facility Section — Spec sheet style -->
  <section class="bg-light tech-grid-bg py-24 lg:py-32" aria-labelledby="facility-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl lg:mb-16" data-animate="fade-up">
        <p class="spec-label mb-3">{t('home.facility.label')}</p>
        <h2 id="facility-heading" class="text-3xl font-black tracking-tight text-dark text-balance sm:text-4xl">
          {t('home.facility.heading')}
        </h2>
        <div class="mt-4 h-0.5 w-16 bg-secondary"></div>
        <p class="mt-4 text-lg text-gray-medium max-w-prose">
          {t('home.facility.description')}
        </p>
      </div>

      <div class="mb-12" data-animate="fade-up">
        <img src="/images/warehouse.jpg" alt={t('home.facility.warehouseAlt')} loading="lazy" decoding="async" width="800" height="600" class="w-full h-56 object-cover object-center" style="aspect-ratio: 800/600;" />
      </div>

      <div class="border border-border" data-animate="fade-up">
        <div class="spec-grid grid gap-px bg-border sm:grid-cols-2 lg:grid-cols-3" data-animate-stagger="scale">
          {specs.map((spec) => (
            <div class="spec-row bg-white p-8 border-l-0 transition-all duration-200 min-w-0">
              <span class="spec-label text-xs">{spec.label}</span>
              <p class="mt-2 text-base font-bold text-dark break-words">{spec.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Section divider -->
  <hr class="section-hr" />

  <!-- Future Plans Section -->
  <section class="bg-white py-20 lg:py-28" aria-labelledby="future-heading">
    <div class="border-t border-border"></div>
    <div class="mx-auto max-w-7xl px-4 pt-16 sm:px-6 lg:px-8 lg:pt-20">
      <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-16">
        <div data-animate="blur-in">
          <span class="spec-label inline-block border border-secondary bg-secondary/5 px-3 py-1 mb-6 text-secondary-dark">{t('home.future.badge')}</span>
          <h2 id="future-heading" class="text-3xl font-black text-dark text-balance sm:text-4xl lg:text-5xl">
            {t('home.future.heading')}
          </h2>
          <div class="mt-4 h-0.5 w-16 bg-secondary"></div>
          <p class="mt-6 text-lg leading-relaxed text-gray-medium max-w-prose">
            {t('home.future.description')}
          </p>
        </div>
        <div class="lg:pt-4" data-animate="fade-left">
          <ul class="space-y-5 border-l-2 border-primary/20 pl-6">
            {benefits.map((benefit) => (
              <li class="flex items-start gap-3 min-w-0">
                <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 bg-secondary" aria-hidden="true"></span>
                <span class="text-base font-medium text-dark/80">{benefit}</span>
              </li>
            ))}
          </ul>
          <a href={localePath(locale, '/contact/')} class="btn mt-10 inline-flex items-center gap-2 rounded-none border-2 border-secondary bg-secondary px-6 py-3 text-base font-bold text-white transition-all duration-200 hover:bg-secondary-dark hover:border-secondary-dark hover:shadow-md">
            {t('home.future.ctaButton')}
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Section divider with green accent -->
  <div class="relative">
    <hr class="section-hr" />
    <div class="absolute left-0 top-0 h-0.5 w-16 bg-secondary"></div>
  </div>

  <!-- CTA Section -->
  <CTA />
</Layout>
